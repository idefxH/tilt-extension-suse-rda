# tilt-extension-suse-rda — suse_app() helper.
#
# Wraps Cloud Native Buildpacks (via `pack`), Helm install, and service
# port-forwarding into a single declarative call. Designed for projects
# scaffolded by `rda new` from a SUSE Rancher Developer Access opinion
# bundle, but usable from any Tiltfile that wants the same conventions.
#
# Usage in a project's Tiltfile:
#
#   load_dynamic('https://raw.githubusercontent.com/idefxH/tilt-extension-suse-rda/main/Tiltfile')
#   suse_app(
#       name='my-app',
#       language='nodejs',
#   )
#
# That replaces ~30 lines of docker_build / helm / k8s_resource boilerplate
# with one call. Service port-forwards are auto-discovered from the
# project's values.yaml (under deploy/ on bundle 0.11.13+ scaffolds, or
# chart/ on older ones — chart_path defaults to auto-detection): every
# `suse-library.services[]` entry (the unified DSL written by `rda
# add-service`) is registered. The app's HTTP port is read from
# `suse-library.port` in the same values.yaml — values.yaml is the source
# of truth, so the Tiltfile stays terse. Override builder_image when
# SUSE-AppCo buildpacks ship.
#
# Pass `services={'<binding>': '<type>'}` explicitly only when you want to
# register a service the chart doesn't deploy itself, or narrow the
# auto-discovered set to a subset.

# Allow `local()` against whatever kube context is currently active.
# Tilt refuses to run `local()` when the active context isn't on its
# built-in allowlist (kind, microk8s, minikube, docker-desktop, …)
# because a `local()` against a prod cluster could nuke prod from a
# dev's laptop. This extension shells out via `local()` for helm
# dep-update bootstrap, the chart-alignment script, `rda namespace
# expand`, etc. — all unavoidable — so the refusal blocks the whole
# Tiltfile. CI runs (GitHub Actions + k3s, context `rancher-desktop`)
# and any custom context name (k3d-*, a user's kubectl rename) trip it.
#
# Must be called at module top level: Tilt resolves the allowlist
# before any function body runs, so calling it from inside suse_app()
# is too late — the first `local()` inside suse_app() blows up before
# the allowlist mutation takes effect.
#
# Safe to allow whatever context is active: the user already pointed
# kubectl at it and ran `tilt up` against it — that's the trust
# decision. allow_k8s_contexts is additive and idempotent.
allow_k8s_contexts(k8s_context())

# Heroku CNB builder. Multi-arch (linux/amd64 + linux/arm64) so the
# buildpack inner loop runs natively on Apple Silicon — no Rosetta, no
# binfmt_misc shenanigans, no /usr/bin/env: 'node': No such file or
# directory at the npm-install step.
#
# Why not Paketo: paketobuildpacks/builder-* are amd64-only as of
# 2026-04-27. Running them on arm64 hosts forces the lifecycle through
# Rosetta inside Rancher Desktop's containerd VM, where binfmt_misc
# handler resolution is unreliable for nested execve in pack's
# ephemeral-lifecycle container. Reproduces with every Paketo tag we
# tested (jammy-base, jammy-full, all versions). Net: not actionable on
# our side until Paketo or AppCo publishes an arm64 builder. Tracked in
# tilt-extension-suse-rda#1 for the AppCo migration.
#
# Heroku 24 series: builder ~400MB (vs Paketo full 1.5GB), ships
# heroku/nodejs (active, v5.5.8 on 2026-04-16), heroku/python,
# heroku/go, heroku/java, heroku/ruby. Run image: heroku/heroku:24.
DEFAULT_BUILDER = 'heroku/builder:24'

# Per-language defaults. Live-update paths follow each buildpack's
# expected workspace layout. Languages requiring a full rebuild on every
# change (compiled) leave live_update_paths empty — Tilt rebuilds via
# pack on file change, with Paketo's layer cache providing the speed-up.
LANGUAGE_DEFAULTS = {
    'nodejs': {
        # heroku/nodejs in v5+ is a unified single buildpack that handles
        # engine resolution + npm install internally. The previous
        # sub-buildpacks are deprecated in v5.
        # Requires a committed package-lock.json so heroku/nodejs runs
        # npm ci (the bundle template ships one).
        # heroku/procfile reads ./Procfile to register processes —
        # 'web' for prod, 'dev' for tilt builds (nodemon -L src/index.js).
        'buildpacks': ['heroku/nodejs', 'heroku/procfile'],
        'live_update_paths': ['./src'],
        'live_update_install_trigger': ['./package.json', './package-lock.json'],
        'live_update_install_cmd': 'cd /workspace && npm install --production=false',
        # Tilt builds run the 'dev' process (nodemon -L src/index.js).
        # nodemon polls every 1s — robust against containerd/overlayfs
        # inotify quirks that break node --watch in some k8s setups.
        # Production builds (no --default-process flag) default to 'web'.
        'pack_default_process': 'dev',
        # Force NODE_ENV=development at build so heroku/nodejs runs
        # 'npm ci' instead of 'npm ci --omit=dev' and includes nodemon
        # (which is in devDependencies of the template package.json).
        'pack_build_env': {'NODE_ENV': 'development'},
    },
    'python': {
        'buildpacks': ['heroku/python', 'heroku/procfile'],
        'live_update_paths': ['./src'],
        'live_update_install_trigger': ['./requirements.txt', './pyproject.toml', './Pipfile'],
        'live_update_install_cmd': 'cd /workspace && pip install -r requirements.txt 2>/dev/null || true',
    },
    'java': {
        # heroku/java compiles via Maven/Gradle. heroku/procfile
        # reads ./Procfile to register web/dev process types.
        # Without procfile, the CNB launcher has no default process
        # and the container crashes with "no default process".
        'buildpacks': ['heroku/java', 'heroku/procfile'],
        'live_update_paths': [],
        'live_update_install_trigger': [],
        'live_update_install_cmd': None,
    },
    'go': {
        # heroku/go + heroku/procfile. Go SDK is NOT in the CNB
        # runtime image (heroku/heroku:24), so in-container
        # recompilation (air, go build) is impossible. Every source
        # change triggers a full `pack build` — heroku/go's layer
        # cache keeps rebuilds to ~10-15s after the first one.
        #
        # If a future builder ships Go in the launch image (e.g.
        # SUSE AppCo builder with a `-dev` variant), re-enable
        # live_update_paths and switch dev: to air.
        'buildpacks': ['heroku/go', 'heroku/procfile'],
        'live_update_paths': [],
        'live_update_install_trigger': [],
        'live_update_install_cmd': None,
    },
}

# Optional registry redirect for CI / local-mirror / air-gapped setups.
# When SUSE_RDA_DEFAULT_REGISTRY is set, register it as Tilt's default
# registry so custom_build's $EXPECTED_REF and any chart images get
# rewritten to that host. The e2e harness uses this to point at the
# local kind-mirror (localhost:5000) without having to inject a
# default_registry() into every project Tiltfile.
#
# Top-level on purpose: Tilt requires default_registry() before any
# image builds are registered, so it has to run at extension load
# time — not inside suse_app().
_suse_rda_default_registry = os.getenv('SUSE_RDA_DEFAULT_REGISTRY', '')
if _suse_rda_default_registry:
    default_registry(_suse_rda_default_registry)

# Conventional ports for service types declared in `services`. Used by
# port_forwards so a developer can `psql -h localhost -p 5432`, etc.
# Legacy hardcoded ports — used as fallback when dsl-mappings.yaml
# doesn't declare a port for the chart type (older bundles, charts
# not in the catalog). New charts should declare their port in
# dsl-mappings.yaml instead of adding to this dict.
def suse_app(
        name,
        language=None,
        port=None,
        services=None,
        chart_path=None,
        chart_values_files=None,
        builder_image=None,
        extra_buildpacks=[],
        additional_env={},
        live_update_paths=None,
        ui_labels=None,
        image_ref=None,
        helm_only=False,
        build_path='.'):
    """Build a project image with pack, deploy its Helm chart, and surface
    convenient port-forwards for the app and any declared services.

    Required:
        name (str): project name. Must equal the Helm release name and the
            chart's metadata.name (so the Deployment resource name matches).
        language (str|None): one of 'nodejs', 'python', 'java', 'go'. Drives
            the default buildpacks and live-update behaviour. Optional when
            image_ref or helm_only is set.

    Common:
        port (int|None): HTTP port exposed by the app container. **Default
            None — derived from `suse-library.port` in chart/values.yaml.**
            The library chart already reads `.Values.port` as the
            container's port AND the Service's targetPort, so values.yaml
            is the source of truth. Don't pass this argument unless you
            need to override; if you pass a value that mismatches
            values.yaml, the Tiltfile fails fast (forcing the dev to fix
            the duplication rather than carry two drifting numbers). When
            values.yaml has no `suse-library.port` entry, falls back to
            the library chart's own default of 8080.
        services (dict|None): map of service binding name -> service type.
            Port-forwards are resolved from dsl-mappings.yaml (data-driven).
            Example: {'database': 'postgresql'}.
            **When None (default), services are auto-discovered from
            chart_values_files** — every entry in `suse-library.services[]`
            (the unified DSL) and every chart with `suse-library.<chart>.enabled:
            true` (the legacy gate) is registered. This is the recommended
            mode: `rda service add <type> <binding>` updates values.yaml,
            and Tilt picks up the change on the next reload — nothing in the
            Tiltfile needs to be in lockstep with values.yaml.
            Pass an explicit dict to opt out of auto-discovery (e.g. to
            register a service the chart doesn't deploy itself).
        chart_path (str|None): path to the Helm chart relative to the Tiltfile.
            **Default None — auto-detected.** Prefers 'deploy/' (the new
            convention from bundle 0.11.13+ scaffolds, where the directory
            name signals the directory's purpose: it's what gets deployed
            to Kubernetes). Falls back to 'chart/' for projects scaffolded
            before the rename. Pass a path explicitly to override (e.g.
            'helm/' for a non-scaffold project, or 'chart' to force the
            legacy name during migration).
        chart_values_files (list[str]): values files passed to helm. Default
            [chart_path + '/values.yaml'] (so values.yaml is resolved inside
            the chart directory). Override with paths relative to the Tiltfile
            if your project keeps values somewhere else.

    Brownfield:
        image_ref (str|None): pre-built container image (e.g.
            'registry.corp.com/my-app:v2.3.1'). Skips pack build entirely
            and passes image.repository + image.tag to helm.
        helm_only (bool): when True, skip ALL image management. The user
            provides their image through their own mechanism. Just helm
            deploy + port-forwards.

    Override:
        builder_image (str): CNB builder image. Default Paketo full builder.
            Override when SUSE-AppCo buildpacks ship:
            builder_image='registry.suse.com/rda/builder:latest'.
        extra_buildpacks (list[str]): additional CNB buildpacks appended to
            the language defaults. Useful for the future SUSE OTel buildpack
            or a service-binding buildpack.
        additional_env (dict): build-time env vars passed via `pack build --env`.
            E.g. {'BP_NODE_VERSION': '22'}.
        live_update_paths (list[str]): override default sync paths. Pass an
            empty list to disable live_update entirely.
        ui_labels (dict): map of resource name -> Tilt UI label. Defaults
            map the app to 'app', services to 'services'.
    """
    if not helm_only and not image_ref:
        if language not in LANGUAGE_DEFAULTS:
            fail('suse_app: unsupported language %r. Supported: %s' % (
                language, ', '.join(sorted(LANGUAGE_DEFAULTS.keys()))))

    # Auto-detect chart_path when caller didn't pass one. Prefer deploy/
    # (bundle template 0.11.13+ scaffolds) and fall back to chart/ (older
    # scaffolds). Project Tiltfiles that pass chart_path='chart' or
    # chart_path='deploy' explicitly bypass this — explicit always wins.
    # Final fallback to 'chart' for projects with neither directory yet
    # (preserves the historical default so existing tests / fixtures keep
    # working).
    # Note: Tilt's Starlark `os.path` exposes `exists()` but NOT `isdir()`
    # (verified at runtime — the latter raises 'module has no .isdir field
    # or method'). We probe for `<dir>/Chart.yaml` instead, which is a
    # tighter signal anyway: a deploy/ or chart/ that doesn't carry a
    # Chart.yaml is useless to helm regardless of its directory-ness.
    if chart_path == None:
        if os.path.exists('deploy/Chart.yaml'):
            chart_path = 'deploy'
        elif os.path.exists('chart/Chart.yaml'):
            chart_path = 'chart'
        else:
            chart_path = 'chart'

    # ─── Stage auto-detection ──────────────────────────────────────────
    # Resolve the RDA stage once, used by every `rda render --stage`
    # call below. Priority:
    #   1. RDA_STAGE env var (explicit override, e.g. CI).
    #   2. .rda/stage file at the project root (written by `rda stage`).
    #   3. Fallback to 'dev' (safe default for inner-loop).
    _stage = os.getenv('RDA_STAGE', '')
    if not _stage:
        _stage_file = os.path.join(chart_path, '..', '.rda', 'stage')
        if os.path.exists(_stage_file):
            _stage = str(read_file(_stage_file)).strip()
    if not _stage:
        _stage = 'dev'

    labels = ui_labels or {}

    # ─── Namespace + pullsecret mirror (must run EARLY) ─────────────────
    # Resolve the deploy namespace, ensure it exists, and mirror the
    # application-collection imagePullSecret BEFORE any image builds are
    # registered or `helm dep update` work begins. Two reasons:
    #
    #   1. Race window: registering custom_build / k8s_yaml later in this
    #      function queues those for Tilt's reconciler. Pods that pull
    #      from dp.apps.rancher.io land on ImagePullBackOff if the secret
    #      isn't already in the target NS the moment kubelet first sees
    #      the pod spec. With this block at the bottom of the function,
    #      slow `helm dep update` runs left a window where pods could be
    #      scheduled before kubectl finished the mirror. The e2e harness
    #      worked around this by pre-creating namespaces (and the secret)
    #      itself — that workaround can go away now that the mirror runs
    #      before any workload registration in this function.
    #
    #   2. Same `local()` calls, same logic — only the position moved.
    #      Functionally identical for the single-NS case; the win is the
    #      ordering guarantee versus image-build / k8s_yaml registration
    #      below.
    #
    # Namespace expansion: shell out to `rda namespace expand` (single
    # source of truth, rda-cli 0.1.47+), with a Starlark fallback for
    # older rda binaries. Reads `.rda/project.yaml` namespace.local,
    # substitutes {{.project}} / {{.user}}.
    rda_can_expand = str(local(
        'command -v rda > /dev/null 2>&1 && rda namespace --help > /dev/null 2>&1 && echo yes || echo no',
        quiet=True, echo_off=True)).strip()
    if rda_can_expand == 'yes':
        namespace = str(local('rda namespace expand', quiet=True, echo_off=True)).strip()
        if not namespace:
            fail('suse_app: `rda namespace expand` returned empty output. Check `.rda/project.yaml`.')
    else:
        # Legacy fallback: in-Tiltfile expander (kept simple — covers UC1
        # and UC2 patterns; for richer cases the user should upgrade to
        # rda-cli 0.1.47+ which owns the canonical logic).
        project_meta = read_yaml('.rda/project.yaml', default={})
        ns_template = ((project_meta.get('namespace', {}) or {}).get('local', '') or '{{.project}}')
        user_value = str(local('echo "${USER:-default}"', quiet=True, echo_off=True)).strip() or 'default'
        namespace = ns_template
        for token, value in [('{{.project}}', name), ('{{ .project }}', name),
                             ('{{.user}}', user_value), ('{{ .user }}', user_value)]:
            namespace = namespace.replace(token, value)
        if '{{' in namespace or '}}' in namespace:
            fail((
                'suse_app: namespace template %r contains an unrecognised token ' +
                'after expansion (got %r). Allowed tokens: {{.project}}, {{.user}}. ' +
                'Edit .rda/project.yaml namespace.local to fix, or install rda 0.1.47+ ' +
                'so this extension can shell out to `rda namespace expand` instead.'
            ) % (ns_template, namespace))

    # Pre-create the namespace idempotently. Tilt invokes `helm template`
    # (not `helm install --create-namespace`) so the namespace must exist
    # before k8s_yaml applies the rendered manifests. `kubectl create
    # --dry-run=client | kubectl apply` is idempotent — succeeds whether
    # the namespace is new or already there.
    local(
        'kubectl create namespace ' + namespace +
        ' --dry-run=client -o yaml | kubectl apply -f -',
        quiet=True, echo_off=True)

    # Mirror the application-collection imagePullSecret from `default` to
    # the deploy namespace if it's missing. Background:
    #   - The Application Collection Rancher Desktop extension installs
    #     the Secret in `default` only. With NS Phase A (rda 0.1.43+),
    #     every project deploys to its own namespace (`{{.project}}` or
    #     a multi-dev `{{.project}}-{{.user}}` template), so the Secret
    #     is never automatically present where it's needed.
    #   - The pod's spec carries `imagePullSecrets: [application-collection]`
    #     unconditionally. Without the Secret in NS, kubelet logs
    #     `Unable to retrieve some image pull secrets`. App image pulls
    #     from dp.apps.rancher.io (BCI base, AppCo subchart images) all
    #     fail with ImagePullBackOff — locally Tilt can mask this by
    #     building images itself, but any real subchart pull cracks open.
    #
    # Strategy:
    #   1. If the target NS already has the Secret → skip silently.
    #   2. Else if `default` has it → kubectl get -o yaml | sed | apply.
    #      Strips namespace + cluster-bound metadata so apply lands in
    #      the new ns. Idempotent (apply, not create).
    #   3. Else loud failure with the remediation hint pointing at
    #      `helm registry login` + the AppCo extension docs.
    #
    # Three escape hatches to coexist with operator-managed distribution
    # (kubernetes-reflector / External Secrets / GitOps / manual):
    #
    #   1. Env var SUSE_RDA_SKIP_PULLSECRET_MIRROR=1 (cluster-wide).
    #   2. Namespace label rda.suse.com/pullsecret-managed-by=operator
    #      — set this on a project NS to declare "an operator owns the
    #      pullsecret here, hands off". Per-NS, persistent in YAML.
    #   3. Source-side annotation: if Secret/application-collection in
    #      `default` carries `external-secrets.io/owned-by` or
    #      `reflector.v1.k8s.emberstack.com/reflection-allowed=true` we
    #      take that as proof an operator distributes it and we step
    #      back — letting the operator's controller reconcile in its
    #      own time on the project NS.
    #
    # Step 0 (target-NS already has it) is the universal safety net:
    # whatever distribution mechanism wrote it first, we don't touch.
    if os.getenv('SUSE_RDA_SKIP_PULLSECRET_MIRROR', '') != '1':
        local(
            "set -e; " +
            # Step 0: target NS already has the Secret — done.
            "if kubectl get secret -n " + namespace + " application-collection " +
            ">/dev/null 2>&1; then exit 0; fi; " +
            # Step 0b: target NS is operator-managed via label.
            "if [ \"$(kubectl get ns " + namespace + " -o " +
            "jsonpath='{.metadata.labels.rda\\.suse\\.com/pullsecret-managed-by}' " +
            "2>/dev/null)\" = 'operator' ]; then " +
            "echo '[suse_rda] skipping pullsecret mirror " +
            "(ns " + namespace + " labelled rda.suse.com/pullsecret-managed-by=operator)'; " +
            "exit 0; fi; " +
            # Step 0c: source Secret is operator-managed (ESO / reflector).
            # Don't fight the operator — step back and let its controller
            # propagate to the project NS on its own.
            "if [ -n \"$(kubectl get secret -n default application-collection -o " +
            "jsonpath='{.metadata.annotations.external-secrets\\.io/owned-by}' " +
            "2>/dev/null)\" ]; then " +
            "echo '[suse_rda] skipping pullsecret mirror " +
            "(default Secret has external-secrets.io annotation; ESO will distribute)'; " +
            "exit 0; fi; " +
            "if [ \"$(kubectl get secret -n default application-collection -o " +
            "jsonpath='{.metadata.annotations.reflector\\.v1\\.k8s\\.emberstack\\.com/reflection-allowed}' " +
            "2>/dev/null)\" = 'true' ]; then " +
            "echo '[suse_rda] skipping pullsecret mirror " +
            "(default Secret has reflector annotation; kubernetes-reflector will distribute)'; " +
            "exit 0; fi; " +
            # Step 1: source missing — loud fail.
            "if ! kubectl get secret -n default application-collection " +
            ">/dev/null 2>&1; then " +
            "echo '[suse_rda] FATAL: Secret/application-collection not found " +
            "in `default` (the AppCo Rancher Desktop extension would normally " +
            "install it there). Either install/launch the AppCo extension, " +
            "OR run `helm registry login dp.apps.rancher.io` then bootstrap " +
            "the Secret manually via kubectl create secret docker-registry; " +
            "OR set SUSE_RDA_SKIP_PULLSECRET_MIRROR=1 if your cluster uses " +
            "kubernetes-reflector / External Secrets to distribute it.' >&2; " +
            "exit 1; fi; " +
            # sed strips instance-bound metadata (namespace + uid +
            # resourceVersion + creationTimestamp) so the doc is
            # namespace-portable. kubectl apply -n <target> then anchors
            # it to the deploy NS. No jq dep — macOS doesn't ship one.
            "kubectl get secret -n default application-collection -o yaml | " +
            "sed -e '/^  namespace:/d' " +
            "-e '/^  uid:/d' " +
            "-e '/^  resourceVersion:/d' " +
            "-e '/^  creationTimestamp:/d' | " +
            "kubectl apply -n " + namespace + " -f - >/dev/null && " +
            "echo '[suse_rda] mirrored Secret/application-collection " +
            "default -> " + namespace + "'",
            quiet=False, echo_off=True)

    # ─── Workloads[] detection ──────────────────────────────────────────
    # New DSL (bundle v0.11+): `suse-library.workloads[]` array in
    # values.yaml. Each workload carries its own image, port, ingress,
    # shape. When present, custom_build and k8s_resource iterate the
    # array; when absent, we fall back to the legacy single-image mode
    # so projects that haven't migrated keep working.
    _primary_values_file = chart_path + '/values.yaml'
    if chart_values_files != None and len(chart_values_files) > 0:
        _primary_values_file = chart_values_files[0]
    _early_values = read_yaml(_primary_values_file, default={})
    _early_lib = (_early_values.get('suse-library', {}) or {})
    _workloads = _early_lib.get('workloads') or []

    # ─── Image strategy: pack build / pre-built image / helm-only ───
    if helm_only:
        pass
    elif image_ref:
        # Pre-built image: parse registry/repo:tag and pass to helm.
        # No pack build, no custom_build. Tilt just deploys the image.
        if ':' in image_ref:
            _img_repo, _img_tag = image_ref.rsplit(':', 1)
        else:
            _img_repo = image_ref
            _img_tag = 'latest'
    else:
        defaults = LANGUAGE_DEFAULTS[language]
        builder = builder_image or DEFAULT_BUILDER
        buildpacks = defaults['buildpacks'] + extra_buildpacks
        sync_paths = live_update_paths if live_update_paths != None else defaults['live_update_paths']

        cache_dir = '/tmp/rda-pack-cache-' + name
        pack_args = ['pack', 'build', '$EXPECTED_REF',
                     '--cache', '"type=build;format=bind;source=' + cache_dir + '"',
                     '--cache', '"type=launch;format=bind;source=' + cache_dir + '-launch"',
                     '--builder', builder]
        for bp in buildpacks:
            pack_args.extend(['--buildpack', bp])
        for k, v in additional_env.items():
            pack_args.extend(['--env', '%s=%s' % (k, v)])
        dev_proc = defaults.get('pack_default_process')
        if dev_proc:
            # Only pass --default-process if the Procfile actually declares
            # that process name. Brownfield apps typically only have 'web:';
            # forcing 'dev' would crash pack build with "tried to set dev to
            # default but it doesn't exist".
            _procfile_path = build_path + '/Procfile'
            _has_dev_proc = False
            if os.path.exists(_procfile_path):
                _pf_content = str(read_file(_procfile_path))
                for _pf_line in _pf_content.splitlines():
                    if _pf_line.startswith(dev_proc + ':'):
                        _has_dev_proc = True
                        break
            if _has_dev_proc:
                pack_args.extend(['--default-process', dev_proc])
        for k, v in (defaults.get('pack_build_env') or {}).items():
            pack_args.extend(['--env', '%s=%s' % (k, v)])
        pack_args.extend(['--path', build_path])
        pack_cmd = ' '.join(pack_args)

        if language == 'go' and os.path.exists('go.mod'):
            local(
                "set -e; " +
                "if ! command -v go >/dev/null 2>&1; then " +
                "echo '[suse_rda] go not on PATH; skipping go mod tidy preflight' >&2; " +
                "exit 0; fi; " +
                "if [ ! -f go.sum ] || [ go.mod -nt go.sum ]; then " +
                "echo '[suse_rda] running go mod tidy (go.sum missing or stale)'; " +
                "go mod tidy; " +
                "fi",
                quiet=False, echo_off=True,
            )

        live_update_steps = []
        for path in sync_paths:
            sync_target = '/workspace/' + path.lstrip('./')
            live_update_steps.append(sync(path, sync_target))
        install_cmd = defaults.get('live_update_install_cmd')
        install_trigger = defaults.get('live_update_install_trigger', [])
        if install_cmd and install_trigger:
            live_update_steps.append(run(install_cmd, trigger=install_trigger))

        deps = sync_paths if sync_paths else ['.']

        # custom_build push semantics: on dev machines (Rancher Desktop,
        # Mac Docker) the local Docker daemon and the cluster's container
        # runtime share containerd, so a pack build that lands in the
        # daemon is immediately visible to the cluster — no push needed.
        # That's the default: skips_local_docker=True + disable_push=True
        # ("the build command handled the push; Tilt, stay out of the way").
        #
        # In CI against a separate k8s (k3s with its own containerd, kind,
        # k3d, …) the image must reach the cluster via a real registry.
        # Pack doesn't publish without --publish, so Tilt has to push the
        # daemon-resident image to default_registry itself. Flipping both
        # flags to False lets Tilt do that: it inspects the local daemon
        # for the pack-tagged image and `docker push`-es it to the
        # registry configured by default_registry().
        #
        # Opt-in via env var so dev behaviour stays unchanged.
        _local_push = os.getenv('SUSE_RDA_TILT_PUSH_TO_REGISTRY') == '1'
        _skips_local_docker = not _local_push
        _disable_push = not _local_push

        if _workloads:
            # Workloads[] mode: build each workload whose image.tag == 'dev'.
            # Workloads pointing to a real registry image (tag != 'dev') are
            # pre-built and don't need a local pack build.
            for _wl in _workloads:
                _wl_image = _wl.get('image', {}) or {}
                if _wl_image.get('tag') != 'dev':
                    continue
                _wl_repo = _wl_image.get('repository', name)
                custom_build(
                    ref=_wl_repo,
                    command=pack_cmd,
                    deps=deps,
                    ignore=[chart_path, 'deploy', '.rda', 'Tiltfile'],
                    match_in_env_vars=True,
                    skips_local_docker=_skips_local_docker,
                    disable_push=_disable_push,
                    live_update=live_update_steps if live_update_steps else None,
                )
        else:
            # Legacy single-workload mode.
            custom_build(
                ref=name,
                command=pack_cmd,
                deps=deps,
                ignore=[chart_path, 'deploy', '.rda', 'Tiltfile'],
                match_in_env_vars=True,
                skips_local_docker=_skips_local_docker,
                disable_push=_disable_push,
                live_update=live_update_steps if live_update_steps else None,
            )

    # Helm install. Renders the chart at chart_path with the given values
    # files, applies the resulting manifests to the cluster.
    #
    # Run `helm dependency update` recursively. The parent chart vendors
    # the SUSE library chart at charts/suse-library/, and the library chart
    # itself declares oci:// dependencies on AppCo charts (e.g. postgresql).
    # `helm dep update` is non-recursive — it only pulls deps for the path
    # you pass. We walk charts/*/Chart.yaml first, update each, then update
    # the parent. Without this step the AppCo sub-charts never land in
    # charts/suse-library/charts/ and their resources never get rendered.
    # Requires `helm registry login dp.apps.rancher.io` (one-time, typically
    # wired by the AppCo Rancher Desktop extension).
    # Strategy: only run helm dep update INSIDE vendored sub-chart directories.
    # We skip 'helm dep update' on the parent because:
    #   1. The bundle vendors sub-charts as directories under charts/*. helm
    #      template reads them directly — no parent update needed.
    #   2. Running it on the parent repackages directories into .tgz files
    #      and deletes any unmatched charts/, which interferes with the
    #      recursive dep-update step.
    # If the user introduces a non-vendored top-level dep later, they should
    # vendor it (rda convention) or run helm dep update themselves.
    # Embed the chart-version aligning helper inline. Writing it to
    # /tmp at runtime avoids the path-discovery problem with extensions
    # loaded via ext:// (no __file__ equivalent in Starlark, and
    # read_file() resolves relative to the user's project Tiltfile).
    align_script_path = '/tmp/_suse_rda_align_subchart_versions.py'
    align_script_src = r'''#!/usr/bin/env python3
"""
Align vendored sub-chart Chart.yaml versions with the parent's dep
declarations.

AppCo (and possibly other) Helm charts publish OCI artifact tags that
don't match the chart's internal Chart.yaml version (e.g. tag
"0.4.4-29.1", chart version "0.4.4"). Helm's dep-matching at template
time uses the chart's INTERNAL version, so the alias the parent
declared silently fails to resolve and parent values never reach the
sub-chart. The pulled tgz is correct; we just need to rewrite its
Chart.yaml so the version matches what the parent says.

Usage: align_subchart_versions.py <parent-chart-dir>

Walks <parent>/charts/*.tgz; for each, peeks at Chart.yaml, if its
version differs from what <parent>/Chart.yaml's `dependencies` say for
the same chart name, rewrites the tgz with the aligned version.

Idempotent: skips if already aligned.
"""
import glob
import os
import shutil
import sys
import tarfile

def _safe_extract(tf, dest):
    # py3.12+ added the `filter` kwarg + the data_filter helper.
    # py<3.12 doesn't accept `filter=` — fall back to the legacy
    # extractall() (no member sanitisation). Acceptable here because
    # the input is a chart .tgz we just downloaded from our own
    # registry and helm dep update validated.
    if hasattr(tarfile, 'data_filter'):
        tf.extractall(dest, filter='data')
    else:
        tf.extractall(dest)



# We import yaml lazily so a missing PyYAML doesn't crash on charts that
# need no patching.
def _yaml():
    try:
        import yaml
        return yaml
    except ImportError:
        sys.stderr.write(
            "[align_subchart_versions] PyYAML not installed; " +
            "pip3 install pyyaml or run with python3 -m pip install pyyaml\n"
        )
        sys.exit(0)


def main(parent_dir):
    parent_chart_yaml = os.path.join(parent_dir, "Chart.yaml")
    if not os.path.isfile(parent_chart_yaml):
        return
    yaml = _yaml()
    with open(parent_chart_yaml) as f:
        parent = yaml.safe_load(f) or {}
    deps = parent.get("dependencies") or []
    wanted = {d["name"]: d["version"] for d in deps if "name" in d and "version" in d}
    if not wanted:
        return
    subdir = os.path.join(parent_dir, "charts")
    if not os.path.isdir(subdir):
        return
    fixed = 0
    for tgz in glob.glob(os.path.join(subdir, "*.tgz")):
        work = tgz + ".unpack"
        if os.path.isdir(work):
            shutil.rmtree(work)
        os.makedirs(work)
        try:
            with tarfile.open(tgz, "r:gz") as tf:
                _safe_extract(tf, work)  # tarfile filter handling — py3.12+ supports `filter='data'`, older python doesn't
            inner = next(
                (d for d in os.listdir(work) if os.path.isdir(os.path.join(work, d))),
                None,
            )
            if not inner:
                continue
            cy_path = os.path.join(work, inner, "Chart.yaml")
            with open(cy_path) as f:
                cy = yaml.safe_load(f) or {}
            name = cy.get("name")
            want = wanted.get(name)
            if want and cy.get("version") != want:
                cy["version"] = want
                with open(cy_path, "w") as f:
                    yaml.safe_dump(cy, f, default_flow_style=False, sort_keys=False)
                new_tgz = tgz + ".new"
                with tarfile.open(new_tgz, "w:gz") as tf:
                    tf.add(os.path.join(work, inner), arcname=inner)
                os.replace(new_tgz, tgz)
                fixed += 1
                print(
                    "[suse_rda] aligned {0} {1} -> {2}".format(name, cy.get("version"), want),
                    flush=True,
                )
        finally:
            if os.path.isdir(work):
                shutil.rmtree(work)
    if fixed:
        print(
            "[suse_rda] patched {0} sub-chart Chart.yaml version(s) under {1}".format(
                fixed, parent_dir
            ),
            flush=True,
        )


if __name__ == "__main__":
    main(sys.argv[1])
'''
    local('cat > ' + align_script_path + " <<'__SUSE_RDA_PY_EOF__'\n" + align_script_src + "\n__SUSE_RDA_PY_EOF__", echo_off=True, quiet=True)

    # Filter the library chart's deps down to ONLY the sub-charts the
    # project has enabled. Without this, every `helm dep update` pulls
    # all 7+ AppCo charts (postgresql, redis, prometheus, grafana, dex,
    # mariadb, apache-kafka, ...) on every fresh project — even when
    # the dev only enabled mariadb. Triggers AppCo rate-limits in
    # high-iteration workflows (e2e harness, repeated `rda new`).
    #
    # The filter reads the project's values + the rda-render overlay,
    # builds the set of `<chart>.enabled: true` chart names, and
    # rewrites the library chart's Chart.yaml keeping only those deps.
    # Backed up to Chart.yaml.full on first run so subsequent
    # enable/disable cycles can re-derive from the full list.
    #
    # Idempotent: if Chart.yaml.full exists, restore from it before
    # filtering. Safe across rda render re-runs (Tilt fires it on
    # every save in the chart tree).
    filter_script_path = '/tmp/_suse_rda_filter_enabled_deps.py'
    filter_script_src = r'''#!/usr/bin/env python3
"""
Strip the library Chart.yaml deps down to only the sub-charts the
project has enabled in its values. Cuts `helm dep update` work to
the minimum (one OCI pull per actually-used sub-chart) and dodges
AppCo rate-limits.

Usage: filter_enabled_deps.py <library-chart-dir> <values-file>...

Reads each values file, walks `suse-library.<chart>.enabled` AND
top-level `<chart>.enabled` (rda render's overlay shape), unions
the truthy chart names, then rewrites <library>/Chart.yaml keeping
only deps whose `name` matches.

Source-of-truth: <library>/Chart.yaml.full. Created on first run
from the live Chart.yaml. Filtering reads from .full every run so
re-enabling a previously-disabled chart still works.

Idempotent. Outputs one line per kept dep + the full count.
"""
import os
import re
import shutil
import sys


def _yaml():
    try:
        import yaml
        return yaml
    except ImportError:
        # Fail loud, NOT silent. If PyYAML is missing the filter cannot
        # run, every helm dep update pulls every catalogued sub-chart,
        # and any HTTP-source repo (e.g. dex on charts.dexidp.io) that
        # isn't in `helm repo list` triggers a confusing `no cached
        # repository for helm-manager-<hash>` error several layers down.
        # Exit 2 so the caller's `|| { ... }` branch fires with a clear
        # remediation pointing the dev at python3 -m pip install pyyaml
        # in the python3 the host's Tilt actually invokes (which on
        # macOS may differ from the conda one in the dev's shell).
        sys.stderr.write(
            ("[filter_enabled_deps] PyYAML not installed in this python3 " +
             "({0}); install with: python3 -m pip install --break-system-packages pyyaml\n" +
             "(check `which python3` from the same env Tilt runs in — on macOS " +
             "the host's /usr/bin/python3 is often distinct from your shell's.)\n"
            ).format(sys.executable)
        )
        sys.exit(2)


def _is_deploy_provisioning(value):
    """True iff `provisioning` declares an in-cluster deploy.

    `local` (legacy) and `deploy` (current README) both deploy a
    workload (and therefore pull in operator sub-charts via
    chart_defaults). Absent → defaults to `deploy` (deploy-by-default
    matches CLI scaffolds). Everything else — `connect`, `shared`,
    `external`, future values — binds via the binding secret only and
    must NOT enable the sub-chart.
    """
    if value is None or value == "":
        return True
    return value in ("local", "deploy")


def _is_redacted(s):
    """True iff `s` is an rda redacted-secret marker.

    Used as a fallback safety net. The ROOT cause of redacted markers
    leaking into `services[].type` is documented in `_is_overlay_file`
    below: rda render projects services[] into the overlay with
    values_mapping applied, and any service whose values_mapping
    routes `type` through a binding-secret value gets the marker
    written back. This helper catches stragglers that slip past the
    overlay-file skip — e.g. a user values file that's been
    hand-edited from overlay output.
    """
    if not isinstance(s, str):
        return False
    return "[redacted " in s or "[REDACTED " in s


def _is_overlay_file(path):
    """True iff `path` is rda render's generated values overlay.

    rda render projects DSL `services[]` from the user's values.yaml
    into the overlay with `values_mapping` applied. For any service
    whose mapping routes a field through a binding-secret value, the
    overlay's projected field becomes a `[redacted secret <binding>-
    binding:<field>]` marker rather than the original DSL value (e.g.
    `type: '[redacted secret demo-dashboards-binding:type]'` instead
    of `type: grafana`).

    The overlay's clean role is to carry chart-level overrides
    (`<chart>.enabled: true`, `<chart>.image.tag: ...`) for the
    `helm()` step. Its `services[]` block is a derived projection —
    NOT the source of truth — so the filter must read services[] from
    the user's values.yaml ONLY. Otherwise the last-wins merge across
    the values stack lets the overlay's redacted entries clobber the
    clean ones from values.yaml, and every downstream consumer (the
    enabled-set, dep aliasing, branch-version patching, source
    rewriting, the k8s_resource registration loop) sees garbage.

    Path-shape: the overlay is conventionally at
    `<chart-dir>/.rda/values.generated.yaml` (rda-cli v0.1.38+) or
    `<chart-dir>/values.generated.yaml` (legacy, pre-v0.1.38). Both
    are recognised here.
    """
    if not path:
        return False
    p = path.replace("\\", "/")
    return (p.endswith("/.rda/values.generated.yaml") or
            p.endswith("/values.generated.yaml") or
            p == ".rda/values.generated.yaml" or
            p == "values.generated.yaml")


def enabled_charts(values_files, library_dir=None):
    """Union the chart names with .enabled=true across all values files.

    Three shapes supported:
      1. Static `<chart>.enabled: true` under `suse-library` (legacy).
      2. rda render overlay's `suse-library.<chart>.enabled: true`.
      3. DSL `services[]` entries — `services[i].type` + `enabled: true`
         (the modern path, what `rda service add` writes). Critical:
         this filter runs BEFORE `rda render` regenerates the overlay,
         so we can't rely on shape #2 alone — services[] is the only
         source of truth at filter-time on a fresh project.

    Top-level `<chart>.enabled` is also checked as a fallback for the
    rare project that pre-dates the DSL.

    Operator-enabled charts: when `library_dir` is provided, also scan
    `dsl-mappings.yaml`'s `charts.<type>.versions[].chart_defaults` for
    any `<other-chart>.enabled: true` keys, and union those chart names
    too. Required because DSL type names (e.g. `cnpg`) can differ from
    the operator sub-chart they pull in (e.g. `cloudnative-pg`). On a
    cold start (CI), values.generated.yaml is empty so the chart_defaults
    haven't been materialized into the overlay yet — without this lookup
    the operator dep gets filtered out and `k8s_resource` references to
    it fail at runtime with `unknown resource`.
    """
    yaml = _yaml()
    enabled = set()
    SKIP_TOP = {"suse-library", "global", "image", "ingress",
                "imagePullSecrets", "resources", "probes", "metrics",
                "podAnnotations", "service", "name", "replicas",
                "port", "apiVersion", "kind"}
    for path in values_files:
        if not os.path.isfile(path):
            continue
        try:
            with open(path) as f:
                data = yaml.safe_load(f) or {}
        except Exception:
            continue
        if not isinstance(data, dict):
            continue
        is_overlay = _is_overlay_file(path)
        # Shape 1+2: under suse-library.<chart>.enabled — read from ALL
        # files, INCLUDING the overlay. The overlay's whole point is to
        # carry chart-level `<chart>.enabled` overrides written by
        # `rda render` for each service[] entry it processed.
        sl = data.get("suse-library")
        if isinstance(sl, dict):
            for name, sub in sl.items():
                if isinstance(sub, dict) and sub.get("enabled") is True:
                    enabled.add(name)
            # Shape 3: services[] DSL — services[i].type + enabled. The
            # CLI defaults services[].enabled to false in the scaffold,
            # so we only count entries the dev has explicitly flipped to
            # true. Same iteration the library helpers and `rda render`
            # walk; staying consistent here matters.
            #
            # OVERLAY SKIP (root-cause fix for the redacted-type bug):
            # the overlay is a PROJECTION of services[] with
            # values_mapping applied. When a mapping routes `type`
            # through a binding-secret value, the overlay writes
            # `type: '[redacted secret demo-<binding>-binding:type]'`
            # instead of the plain DSL type. Reading services[] from
            # the overlay then lets the marker into the enabled set,
            # which propagates into Chart.yaml dep names and downstream
            # k8s_resource() lookups. The user's values.yaml is the
            # source of truth for services[]; the overlay is a
            # downstream artefact and must NOT be re-read here.
            #
            # Provisioning gate: only `local`/`deploy` modes deploy an
            # in-cluster workload (and pull in operator sub-charts via
            # chart_defaults below). `connect`/`shared`/`external` modes
            # bind to a pre-existing instance via the binding secret only
            # — they MUST NOT add the chart to the enabled set, otherwise
            # `helm dep update` pulls the operator chart and `helm install`
            # deploys it (e.g. cloudnative-pg operator for a postgresql
            # service that's actually pointing at an external DB).
            services = [] if is_overlay else (sl.get("services") or [])
            if isinstance(services, list):
                # Count types for multi-instance alias computation (#24).
                # Only count deploy-mode entries — connect-mode siblings
                # don't compete for an alias slot. Redacted-type entries
                # are also skipped so the redacted marker never reaches
                # the enabled set (which would propagate into Chart.yaml
                # dep names and `helm dep update` failures).
                type_counts = {}
                for entry in services:
                    if not isinstance(entry, dict):
                        continue
                    if not _is_deploy_provisioning(entry.get("provisioning")):
                        continue
                    t = entry.get("type")
                    if not t or _is_redacted(t):
                        continue
                    type_counts[t] = type_counts.get(t, 0) + 1
                for entry in services:
                    if not isinstance(entry, dict):
                        continue
                    if entry.get("enabled", True) is False:
                        continue
                    if not _is_deploy_provisioning(entry.get("provisioning")):
                        continue
                    chart_type = entry.get("type")
                    binding = entry.get("binding", "")
                    if not chart_type:
                        continue
                    if _is_redacted(chart_type):
                        sys.stderr.write(
                            ("[filter_enabled_deps] skipping services[binding={0!r}]: " +
                             "type={1!r} is a redacted secret marker. The DSL type " +
                             "must be a plain string (e.g. 'grafana'); a redacted " +
                             "value here usually means dsl-mappings.yaml chained " +
                             "`services[].type` through a binding-secret value_mapping. " +
                             "Sub-chart is not added to the enabled set; fix the " +
                             "mapping in the bundle to route `type` from project " +
                             "values, not from a secret.\n").format(binding, chart_type)
                        )
                        continue
                    enabled.add(chart_type)
                    # Multi-instance: also add the aliased name.
                    if type_counts.get(chart_type, 0) > 1 and binding:
                        enabled.add(chart_type + "-" + binding)
        # Top-level fallback (legacy / non-DSL projects).
        for name, sub in data.items():
            if name in SKIP_TOP:
                continue
            if isinstance(sub, dict) and sub.get("enabled") is True:
                enabled.add(name)

    # Operator chart_defaults expansion: for each enabled DSL type, pull
    # any `<chart>.enabled: true` keys out of its dsl-mappings entry's
    # chart_defaults and union those chart names too. Snapshot the set
    # first so we only expand from user-declared types, not transitively.
    if library_dir:
        dsl_path = os.path.join(library_dir, "dsl-mappings.yaml")
        if os.path.isfile(dsl_path):
            try:
                with open(dsl_path) as f:
                    dsl = yaml.safe_load(f) or {}
            except Exception:
                dsl = {}
            charts_dsl = dsl.get("charts") or {}
            for t in list(enabled):
                entry = charts_dsl.get(t) or {}
                for ver in (entry.get("versions") or []):
                    if not isinstance(ver, dict):
                        continue
                    for k, v in (ver.get("chart_defaults") or {}).items():
                        if k.endswith(".enabled") and v is True:
                            enabled.add(k[:-len(".enabled")])
    return enabled


def main(library_dir, *values_files):
    chart_yaml = os.path.join(library_dir, "Chart.yaml")
    full_backup = chart_yaml + ".full"
    if not os.path.isfile(chart_yaml):
        return

    # First run: snapshot the live Chart.yaml as the source-of-truth.
    if not os.path.isfile(full_backup):
        shutil.copy2(chart_yaml, full_backup)

    yaml = _yaml()
    with open(full_backup) as f:
        full = yaml.safe_load(f) or {}

    full_deps = full.get("dependencies") or []
    if not full_deps:
        return  # nothing to filter

    enabled = enabled_charts(values_files, library_dir=library_dir)

    # Multi-instance aliasing (#24): expand deps for types with
    # multiple bindings. Read services[] to find multi-instance types,
    # then duplicate the original dep entry with per-binding aliases.
    # SYNC: alias formula is <type>-<binding>. Must match
    # rda-cli/internal/render/alias.go:ComputeAliases.
    expanded_deps = list(full_deps)
    multi_aliases = {}  # type → [alias1, alias2, ...]
    for path in values_files:
        if not os.path.isfile(path):
            continue
        # See _is_overlay_file: services[] in the overlay is a projection
        # with values_mapping applied (potentially with redacted types) —
        # always read services[] from the user's values.yaml only.
        if _is_overlay_file(path):
            continue
        try:
            with open(path) as f:
                data = _yaml().safe_load(f) or {}
        except Exception:
            continue
        sl = data.get("suse-library")
        if not isinstance(sl, dict):
            continue
        services = sl.get("services") or []
        if not isinstance(services, list):
            continue
        type_bindings = {}
        for entry in services:
            if not isinstance(entry, dict):
                continue
            # Connect/shared/external entries don't add a sub-chart, so
            # they MUST NOT count toward multi-instance alias splitting.
            # Otherwise a (deploy, connect) sibling pair would aliase the
            # one deploy dep to <type>-<binding1>, drop it from `enabled`
            # (which still has the bare type), and filter it out — the
            # sub-chart silently disappears.
            if not _is_deploy_provisioning(entry.get("provisioning")):
                continue
            if entry.get("enabled", True) is False:
                continue
            t = entry.get("type", "")
            b = entry.get("binding", "")
            # Redacted types can't be aliased — the resulting key would
            # propagate the marker into `multi_aliases` and ultimately
            # into Chart.yaml dep names. Skip; enabled_charts already
            # warned.
            if _is_redacted(t) or _is_redacted(b):
                continue
            if t and b:
                type_bindings.setdefault(t, []).append(b)
        for t, bindings in type_bindings.items():
            if len(bindings) > 1:
                multi_aliases[t] = [t + "-" + b for b in bindings]

    if multi_aliases:
        new_deps = []
        for d in expanded_deps:
            ename = d.get("alias", d.get("name"))
            if ename in multi_aliases:
                # Replace single dep with N aliased deps.
                for alias in multi_aliases[ename]:
                    aliased = dict(d)
                    aliased["alias"] = alias
                    aliased["condition"] = alias + ".enabled"
                    new_deps.append(aliased)
            else:
                new_deps.append(d)
        expanded_deps = new_deps

    # Branch version patching (DO-0005 Phase 2): when a service declares
    # branch: "16" and dsl-mappings has branches."16".chart_version, patch
    # the dep's version: field so helm dep update pulls the correct chart.
    dsl_path = os.path.join(library_dir, "dsl-mappings.yaml")
    if os.path.isfile(dsl_path):
        try:
            with open(dsl_path) as f:
                dsl = _yaml().safe_load(f) or {}
        except Exception:
            dsl = {}
        charts_dsl = dsl.get("charts") or {}
        branch_versions = {}  # chart_type -> chart_version from branch
        for path in values_files:
            if not os.path.isfile(path):
                continue
            # Skip the overlay — services[] is a derived projection there.
            if _is_overlay_file(path):
                continue
            try:
                with open(path) as f:
                    data = _yaml().safe_load(f) or {}
            except Exception:
                continue
            sl = data.get("suse-library")
            if not isinstance(sl, dict):
                continue
            for entry in (sl.get("services") or []):
                if not isinstance(entry, dict):
                    continue
                t = entry.get("type", "")
                if _is_redacted(t):
                    continue  # fallback guard if overlay-skip missed
                branch = str(entry.get("branch", ""))
                if t and branch and t in charts_dsl:
                    branches = charts_dsl[t].get("branches") or {}
                    if branch in branches:
                        cv = branches[branch].get("chart_version", "")
                        if cv:
                            branch_versions[t] = cv
        for d in expanded_deps:
            dep_name = d.get("alias", d.get("name", ""))
            base_type = dep_name.split("-")[0] if "-" in dep_name else dep_name
            if base_type in branch_versions:
                d["version"] = branch_versions[base_type]

    # Per-service source rewriting (DO-0012): services[] can override
    # the project source with a per-service `source:` field. Read each
    # service's source, look up the target source in dsl-mappings, and
    # rewrite the dep's repo/name/version accordingly.
    if charts_dsl:
        service_sources = {}  # chart_type -> source
        project_source = ""
        project_dir = os.path.dirname(library_dir)
        project_root = os.path.dirname(project_dir)
        project_yaml = os.path.join(project_root, ".rda", "project.yaml")
        if os.path.isfile(project_yaml):
            try:
                with open(project_yaml) as f:
                    proj_meta = _yaml().safe_load(f) or {}
                project_source = proj_meta.get("chart_source", "")
            except Exception:
                pass
        for path in values_files:
            if not os.path.isfile(path):
                continue
            # Skip overlay; services[].source lives in values.yaml.
            if _is_overlay_file(path):
                continue
            try:
                with open(path) as f:
                    data = _yaml().safe_load(f) or {}
            except Exception:
                continue
            sl = data.get("suse-library")
            if not isinstance(sl, dict):
                continue
            for entry in (sl.get("services") or []):
                if not isinstance(entry, dict):
                    continue
                t = entry.get("type", "")
                if _is_redacted(t):
                    continue  # fallback guard if overlay-skip missed
                svc_source = entry.get("source", "")
                if t and svc_source:
                    service_sources[t] = svc_source

        for d in expanded_deps:
            dep_alias = d.get("alias", "")
            dep_name = d.get("name", "")
            chart_type = dep_alias or dep_name
            # infra deps (e.g. cloudnative-pg operator) follow the source
            # of their parent DSL type (cnpg). Check infra_only flag.
            chart_entry_meta = charts_dsl.get(chart_type, {})
            parent_type = chart_type
            if chart_entry_meta.get("infra_only"):
                # Find DSL type that enables this infra dep via chart_defaults
                for svc_t, svc_src in service_sources.items():
                    svc_entry = charts_dsl.get(svc_t, {})
                    for ver in (svc_entry.get("versions") or []):
                        defaults = ver.get("chart_defaults") or {}
                        if any(chart_type in str(k) for k in defaults):
                            parent_type = svc_t
                            break
            svc_source = service_sources.get(parent_type, project_source)
            if not svc_source:
                continue
            chart_entry = charts_dsl.get(chart_type, {})
            sources = chart_entry.get("sources", {})
            target_src = sources.get(svc_source, {})
            if not target_src:
                continue
            target_repo = target_src.get("chart_ref", "")
            target_name = target_src.get("chart_name", "")
            if not target_repo:
                continue
            if d.get("repository", "") != target_repo:
                d["repository"] = target_repo
            if target_name and dep_name != target_name:
                d["name"] = target_name
                if not dep_alias:
                    d["alias"] = chart_type
            elif not target_name and dep_alias and dep_name != chart_type:
                d["name"] = chart_type
                d.pop("alias", None)
            if svc_source == "community":
                ver = d.get("version", "")
                base = re.sub(r'-\d+\.\d+$', '', ver)
                if base != ver:
                    d["version"] = base

    if not enabled:
        kept = []
    else:
        kept = [d for d in expanded_deps if d.get("alias", d.get("name")) in enabled]

    # Final defense: even if a redacted marker slipped past every upstream
    # filter (corrupted Chart.yaml.full, third-party rewrite, future code
    # path), drop any dep whose name or alias contains it. `helm dep update`
    # would fail with a confusing message on such an entry, and we'd rather
    # the user see the warning here than try to debug a chart-resolution
    # error three layers down.
    safe_kept = []
    for d in kept:
        n = d.get("name", "")
        a = d.get("alias", "")
        if _is_redacted(n) or _is_redacted(a):
            sys.stderr.write(
                ("[filter_enabled_deps] dropping dep with redacted-secret " +
                 "marker in name/alias: name={0!r}, alias={1!r}. This usually " +
                 "means a per-service source-rewrite or Chart.yaml.full backup " +
                 "captured a redacted value; delete <library>/Chart.yaml.full " +
                 "and re-run to recover from a clean snapshot.\n").format(n, a)
            )
            continue
        safe_kept.append(d)
    kept = safe_kept

    out = dict(full)  # shallow copy
    out["dependencies"] = kept

    new_content = yaml.safe_dump(out, default_flow_style=False, sort_keys=False)
    # IDEMPOTENT WRITE: only touch Chart.yaml if the content actually
    # differs. Without this guard, Tilt sees Chart.yaml change every
    # reload (because we always rewrite), reloads the Tiltfile (the chart
    # tree is in its watch set), which re-runs this script, which writes
    # again — infinite loop. Tilt's fast-path
    # `Chart.lock newer than Chart.yaml` also never triggers because
    # we keep bumping Chart.yaml's mtime. See tilt-extension #URGENT.
    try:
        with open(chart_yaml) as f:
            cur_content = f.read()
    except OSError:
        cur_content = None
    wrote = (cur_content != new_content)
    if wrote:
        with open(chart_yaml, "w") as f:
            f.write(new_content)
        # When repos changed (source switch), delete stale .tgz files
        # and Chart.lock to force helm dep update to re-pull.
        charts_subdir = os.path.join(library_dir, "charts")
        if os.path.isdir(charts_subdir):
            for tgz in os.listdir(charts_subdir):
                if tgz.endswith(".tgz"):
                    os.remove(os.path.join(charts_subdir, tgz))
        lock = os.path.join(library_dir, "Chart.lock")
        if os.path.isfile(lock):
            os.remove(lock)

    skipped = len(full_deps) - len(kept)
    suffix = "" if wrote else " (unchanged on disk)"
    print(
        ("[suse_rda] filter_enabled_deps: kept {0}/{1} sub-chart(s) " +
         "[{2}]; skipped {3} disabled{4}").format(
            len(kept), len(full_deps),
            ", ".join(sorted([d.get("name", "?") for d in kept])) or "none",
            skipped, suffix,
        ),
        flush=True,
    )


if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("usage: filter_enabled_deps.py <library-chart-dir> <values-file>...",
              file=sys.stderr)
        sys.exit(2)
    main(*sys.argv[1:])
'''
    local('cat > ' + filter_script_path + " <<'__SUSE_RDA_PY_EOF__'\n" + filter_script_src + "\n__SUSE_RDA_PY_EOF__", echo_off=True, quiet=True)

    # Pre-flight helper: ensure every non-OCI repo URL referenced by the
    # library Chart.yaml is registered with `helm repo add` BEFORE
    # `helm dep update --skip-refresh` runs. Without this, the first
    # `tilt up` of any project that vendors a library with a fresh HTTP
    # source (e.g. dex on charts.dexidp.io) crashes with a confusing
    #   `Error: no cached repository for helm-manager-<sha>`
    # because `--skip-refresh` forbids the on-the-fly index fetch.
    #
    # OCI repos (oci://dp.apps.rancher.io/charts) are skipped — Helm
    # talks to them directly without an index cache.
    bootstrap_repos_script_path = '/tmp/_suse_rda_bootstrap_helm_repos.py'
    bootstrap_repos_script_src = r'''#!/usr/bin/env python3
"""
Walk a library chart's Chart.yaml.full (or Chart.yaml as fallback) and
ensure every HTTP/HTTPS repository: URL is registered with helm. We
read .full because filter_enabled_deps strips Chart.yaml down to the
enabled subset — but a previously-disabled chart on an HTTP repo could
get re-enabled later, and we want the index ready when it does.

OCI repos are skipped (Helm doesn't cache an index for them).
Idempotent: helm repo add fails when a name+url is already registered;
we tolerate that.

Usage: bootstrap_helm_repos.py <library-chart-dir>
"""
import hashlib
import os
import re
import subprocess
import sys


def _yaml():
    try:
        import yaml
        return yaml
    except ImportError:
        sys.stderr.write(
            ("[bootstrap_helm_repos] PyYAML not installed in this python3 " +
             "({0}); install with: python3 -m pip install --break-system-packages pyyaml\n"
            ).format(sys.executable)
        )
        sys.exit(2)


def _existing_repo_urls():
    try:
        out = subprocess.check_output(
            ["helm", "repo", "list", "-o", "yaml"],
            stderr=subprocess.DEVNULL,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return set()
    yaml = _yaml()
    data = yaml.safe_load(out) or []
    return {(item.get("name"), item.get("url")) for item in data if isinstance(item, dict)}


def _safe_name_for_url(url):
    # Helm repo names are short ascii. Use a slugified host + 6-char hash
    # so reruns produce the same name and `helm repo add` is idempotent.
    host = re.sub(r"^https?://", "", url).split("/")[0]
    slug = re.sub(r"[^a-z0-9]+", "-", host.lower()).strip("-") or "repo"
    short = hashlib.sha256(url.encode()).hexdigest()[:6]
    return "rda-{0}-{1}".format(slug, short)


def main(library_dir):
    chart_yaml = os.path.join(library_dir, "Chart.yaml.full")
    if not os.path.isfile(chart_yaml):
        chart_yaml = os.path.join(library_dir, "Chart.yaml")
    if not os.path.isfile(chart_yaml):
        return
    yaml = _yaml()
    with open(chart_yaml) as f:
        doc = yaml.safe_load(f) or {}
    deps = doc.get("dependencies") or []
    http_urls = sorted({
        d.get("repository", "").strip()
        for d in deps if isinstance(d, dict)
        and isinstance(d.get("repository"), str)
        and d["repository"].startswith(("http://", "https://"))
    })
    if not http_urls:
        return
    existing = _existing_repo_urls()
    existing_urls = {url for _, url in existing}
    added = []
    for url in http_urls:
        if url in existing_urls:
            continue
        name = _safe_name_for_url(url)
        try:
            subprocess.check_call(
                ["helm", "repo", "add", name, url],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.STDOUT,
            )
            added.append((name, url))
        except subprocess.CalledProcessError:
            # Likely already registered under a different name — fine,
            # let the subsequent --skip-refresh step succeed regardless.
            pass
    if added:
        print(
            "[suse_rda] bootstrapped {0} HTTP helm repo(s): {1}".format(
                len(added), ", ".join(u for _, u in added)
            ),
            flush=True,
        )
        # The added repos have no cached index yet; refresh just them.
        # `helm repo update <names>` is the targeted form (3.13+).
        try:
            subprocess.check_call(
                ["helm", "repo", "update"] + [n for n, _ in added],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.STDOUT,
            )
        except subprocess.CalledProcessError:
            # Older helm: untargeted update is the fallback.
            subprocess.call(["helm", "repo", "update"], stdout=subprocess.DEVNULL)


if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("usage: bootstrap_helm_repos.py <library-chart-dir>", file=sys.stderr)
        sys.exit(2)
    main(sys.argv[1])
'''
    local('cat > ' + bootstrap_repos_script_path + " <<'__SUSE_RDA_PY_EOF__'\n" + bootstrap_repos_script_src + "\n__SUSE_RDA_PY_EOF__", echo_off=True, quiet=True)

    # Speed: skip helm dep update when the cache is fresh.
    #   - --skip-refresh: don't update the 15+ helm repos (metallb, harbor,
    #     longhorn, rancher, ...). Wasted work because our deps use oci://
    #     URLs that bypass helm's repo cache entirely.
    #   - "Chart.lock newer than Chart.yaml + charts/*.tgz exists" guard:
    #     skip the dep update + alignment loop entirely. Saves ~5-15s per
    #     Tiltfile reload — these reloads happen on every save in the chart
    #     tree, so the win compounds. helm dep build would be even faster
    #     but requires a lock; we keep `update --skip-refresh` for the
    #     first-run / after-upgrade case where the lock isn't present yet.
    helm_dep_script = (
        'set -e; ' +
        'if [ -d "' + chart_path + '/charts" ]; then ' +
        '  for sub in "' + chart_path + '"/charts/*/; do ' +
        '    [ -d "$sub" ] || continue; ' +
        '    [ -f "$sub/Chart.yaml" ] || continue; ' +
        '    grep -q "^dependencies:" "$sub/Chart.yaml" || continue; ' +
        # Filter the library's deps down to only what's enabled in the
        # project's values. Cuts AppCo OCI pulls from N (every catalog
        # chart) to k (only the ones services[] turned on) per scenario.
        # Reads the project's values.yaml + rda render's overlay so the
        # filter sees both static + DSL-derived enabled flags. Idempotent:
        # backs up to Chart.yaml.full on first run, re-derives every run
        # so disable→enable cycles work.
        # No `|| true` here: a missing PyYAML / parse error / write error
        # in the filter would leave Chart.yaml un-filtered and helm
        # would pull every catalog entry, including HTTP-source repos
        # the user hasn't registered. Better to fail loud with the
        # filter's own remediation message than to mask it as a
        # downstream `helm-manager-<sha>` cache miss two layers later.
        '    python3 "' + filter_script_path + '" "$sub" ' +
        '      "' + chart_path + '/values.yaml" ' +
        '      "' + chart_path + '/.rda/values.generated.yaml" || ' +
        '      { echo "[suse_rda] FATAL: filter_enabled_deps.py failed for $sub"; exit 1; }; ' +
        # Pre-flight: register any non-OCI helm repo referenced by the
        # library Chart.yaml.full, so the subsequent
        # `helm dep update --skip-refresh` can find their indexes.
        # Idempotent + cheap. PyYAML required (already enforced above).
        '    python3 "' + bootstrap_repos_script_path + '" "$sub" || ' +
        '      { echo "[suse_rda] FATAL: bootstrap_helm_repos.py failed for $sub"; exit 1; }; ' +
        # Fast-path: lock fresh AND charts/ populated -> skip update.
        '    if [ -f "$sub/Chart.lock" ] && [ "$sub/Chart.lock" -nt "$sub/Chart.yaml" ] && ' +
        '       [ -d "$sub/charts" ] && [ -n "$(ls -A "$sub/charts" 2>/dev/null)" ]; then ' +
        '      echo "[suse_rda] $sub deps up to date, skipping helm dep update"; ' +
        '      python3 "' + align_script_path + '" "$sub"; ' +
        '      continue; ' +
        '    fi; ' +
        '    echo "[suse_rda] helm dep update --skip-refresh $sub"; ' +
        '    helm dependency update --skip-refresh "$sub"; ' +
        # AppCo packaging quirk: their Helm charts publish OCI artifact
        # tags like "0.4.4-29.1" but Chart.yaml inside says version
        # "0.4.4". Helm matches deps against the INTERNAL version, so
        # when the library declares postgresql at "0.4.4-29.1" the alias
        # silently fails to resolve at template time and parent values
        # never reach the sub-chart (no app user, no auth db). Patch
        # each pulled sub-chart to align its internal version with what
        # the parent expects. Drop when AppCo aligns version<->tag.
        '    python3 "' + align_script_path + '" "$sub"; ' +
        '  done; ' +
        'fi'
    )
    local(helm_dep_script, echo_off=True, quiet=False)

    # Note: values.yaml is NOT explicitly watched here. Tilt already
    # watches the chart tree (via helm()), so dev edits to values.yaml
    # trigger a reload naturally. An explicit watch_file would cause an
    # infinite loop when reconcileHints or rda render writes back to
    # values.yaml during the reload.

    # Ignore helm-managed paths so Tilt doesn't reload-loop. helm dep update
    # writes .tgz files into charts/<sub>/charts/, plus tmpcharts-* dirs and
    # Chart.lock. Tilt watches the project tree by default; without these
    # ignores every helm dep update triggers a reload that re-runs helm dep
    # update -> infinite loop.
    # watch_settings(ignore=...) is GLOBAL — files matched are removed
    # from ALL watch trees including live_update sync. So we keep this
    # list narrow: only the helm-managed dynamic paths that would
    # otherwise cause infinite Tiltfile reload loops on helm dep update
    # output. We do NOT include src/ here even though src/ changes do
    # trigger a Tiltfile reload (because helm() watches chart_path
    # recursively) — ignoring src/ would also stop live_update from
    # syncing src/ into the running container.
    #
    # The Tiltfile reload cost on src/ saves is acceptable because:
    #   - the local() helm dep update / alignment cache via Helm's own
    #     state and complete in <1s when nothing changed
    #   - live_update's sync runs in parallel and the runtime watcher
    #     (nodemon -L for nodejs) still picks up the change
    # If users find the reload too noisy, the longer-term fix is to
    # split the chart into a sub-directory so helm() doesn't watch the
    # app source — out of scope for v0.7.
    watch_settings(ignore=[
        chart_path + '/charts/*/charts',
        chart_path + '/charts/*/tmpcharts-*',
        chart_path + '/charts/*/Chart.lock',
        chart_path + '/Chart.lock',
    ])

    # Default values file follows chart_path. Bundle v0.8+ ships values.yaml
    # under chart/, so when chart_path='chart' the defaults are 'chart/values.yaml'.
    # Users overriding chart_values_files pass paths relative to the Tiltfile.
    if chart_values_files == None:
        chart_values_files = [chart_path + '/values.yaml']

    # ─── DSL projection (rda render) ────────────────────────────────────
    # Helm resolves sub-chart values BEFORE templates run, so the library
    # chart's _helpers.tpl can't inject services[].auth.user.name into
    # postgresql.auth.username at template time. The projection has to
    # happen out of band — `rda render` does it pre-helm. We call it here,
    # right before `helm(...)`, so chart/values.generated.yaml is fresh
    # for every tilt up. Spec: idefxH/rda-cli/rda.md BEHAVIOR: render.
    # Closes idefxH/rda-opinion-bundle-example#66.
    #
    # Wiring choices:
    #   - We call `rda render` (NOT --check) at every tilt up. Generating
    #     is fast (millisecond-class for typical projects); --check would
    #     just defer the same work to a second invocation if it found
    #     drift. CI is the right place for --check.
    #   - The generated overlay is APPENDED to chart_values_files so helm
    #     reads the user's values + the projection. Order matters: user
    #     values first (they're the truth), generated overlay second
    #     (Helm's value-merge convention is later-wins, which is what we
    #     want — the projected values_mapping output overrides any stale
    #     manual entries the user may have left from before they adopted
    #     `rda render`).
    #   - Missing rda binary: graceful warning, no fail. Inner-loop dev
    #     against an unreleased rda branch shouldn't be blocked. The
    #     downstream helm template will fail loud anyway via
    #     validateConsistency if the user hasn't manually maintained the
    #     equivalent values.
    rda_present = str(local(
        'command -v rda > /dev/null 2>&1 && echo present || echo missing',
        quiet=True, echo_off=True)).strip()
    if rda_present == 'present':
        # Run from chart_path's parent: `rda render` resolves the project
        # via cwd, and the project's chart_dir is computed relative to
        # the .rda/project.yaml location.
        # Watch .rda/stage at project root (parent of chart_path).
        # No touch — the file must exist before tilt up. If absent,
        # watch_file is a no-op (Tilt ignores missing paths).
        stage_path_root = os.path.join(os.path.dirname(chart_path), '.rda', 'stage')
        watch_file(stage_path_root)
        local('rda render --stage %s' % _stage, quiet=True, echo_off=False)
        # Look for the overlay at the new path first (rda-cli v0.1.38+:
        # chart/.rda/values.generated.yaml), then fall back to the old
        # path (chart/values.generated.yaml) for projects that were
        # rendered with an older CLI. Both are valid; whichever exists
        # is what `helm` should consume. The fallback gets the dev a
        # working tilt up while they upgrade.
        new_overlay = chart_path + '/.rda/values.generated.yaml'
        old_overlay = chart_path + '/values.generated.yaml'
        if os.path.exists(new_overlay):
            generated_overlay = new_overlay
        elif os.path.exists(old_overlay):
            generated_overlay = old_overlay
            print('suse_rda: note — using legacy ' + old_overlay +
                  '. rda-cli v0.1.38+ writes to chart/.rda/values.generated.yaml; ' +
                  'next `rda render` will migrate. You can delete the legacy ' +
                  'file once chart/.rda/values.generated.yaml exists.')
        else:
            generated_overlay = ''
        # Only append when render actually produced the file (it does
        # unconditionally — see render.go's writeAtomic — but stay
        # defensive in case the user is on an older rda binary that
        # predates BEHAVIOR: render).
        if generated_overlay != '':
            # De-dup: if the user already passed the overlay in
            # chart_values_files, don't add it twice (Helm tolerates
            # dup files but the warning would confuse).
            if generated_overlay not in chart_values_files:
                chart_values_files = chart_values_files + [generated_overlay]
    else:
        print('suse_rda: warning — `rda` not on PATH; chart/.rda/values.generated.yaml ' +
              'will not be regenerated. Install rda CLI to keep services[] DSL ' +
              'in sync with sub-chart values. See idefxH/rda-cli.')

    helm_set = []
    if image_ref:
        helm_set.append('image.repository=' + _img_repo)
        helm_set.append('image.tag=' + _img_tag)

    # Check for ingress hostname conflicts with other namespaces.
    # Two projects with the same ingress host (e.g. auth.localtest.me)
    # cause Traefik to route to the wrong service silently.
    _check_ingress_conflicts(chart_path, chart_values_files, namespace)

    k8s_yaml(helm(
        chart_path,
        name=name,
        namespace=namespace,
        values=chart_values_files,
        set=helm_set,
    ))

    # Surface the application Service on the requested port. Convention:
    # local port == container port, so curl http://localhost:<port> works
    # the same as in production behind an Ingress.
    #
    # Auto-discover ingress hosts from the project's values.yaml so the
    # Tilt resource card shows clickable Ingress links alongside the
    # port-forward. Reads `suse-library.ingress` for the app, and each
    # sub-chart's own ingress block for the services (grafana follows
    # the standard `<chart>.ingress` shape; prometheus puts it under
    # `<chart>.server.ingress`). User-defined values files override
    # these via Tilt's standard --values stacking.
    parsed_values = []
    parsed_values_paths = []
    for vfile in chart_values_files:
        parsed_values.append(read_yaml(vfile, default={}))
        parsed_values_paths.append(vfile)

    # Match the embedded filter's _is_overlay_file. The rda render
    # overlay is appended LAST to chart_values_files (line ~1538), so a
    # last-wins merge of services[] across parsed_values lets the
    # overlay's projected entries overwrite the clean ones from
    # values.yaml. The overlay's services[] can carry redacted-secret
    # markers (when a values_mapping routes a field through a binding
    # secret) and those markers must not reach the services-discovery
    # loop. The chart-level overrides the overlay carries
    # (`<chart>.enabled`, image tags, etc.) ARE still read — only the
    # services[] block is skipped.
    def _is_overlay_path(p):
        if not p:
            return False
        return (p.endswith('/.rda/values.generated.yaml') or
                p.endswith('/values.generated.yaml') or
                p == '.rda/values.generated.yaml' or
                p == 'values.generated.yaml')

    # Derive `port` from chart/values.yaml when the caller didn't pass one.
    # The library chart's deployment.yaml renders `containerPort: {{ .Values.port }}`
    # and the Service maps Service.targetPort to the same value, so
    # `suse-library.port` is the canonical container port. Reading it
    # here keeps the Tiltfile DRY: callers don't have to remember to set
    # the same number in two places. Closes the same drift class as
    # rda-cli#65 (single source of truth).
    #
    # Resolution order (last wins, matches Helm's --values stacking):
    #   1. library chart default (8080)
    #   2. user's chart/values.yaml suse-library.port
    #   3. user-overridden values files
    #   4. explicit port=NNN in suse_app(...) — fails fast on mismatch
    if not _workloads:
        # Legacy single-workload port discovery.
        discovered_port = 8080
        for cfg in parsed_values:
            lib = (cfg.get('suse-library', {}) or {}) if cfg else {}
            if 'port' in lib:
                discovered_port = lib['port']
        if port == None:
            port = discovered_port
        elif port != discovered_port:
            fail((
                'suse_app: port=%d passed explicitly but chart/values.yaml has ' +
                'suse-library.port=%d. The two would drift on every edit. ' +
                'Drop the port argument from suse_app(...) — values.yaml is the ' +
                'source of truth (see rda-docs/concepts/dsl.md). If you really ' +
                'need to override, change values.yaml.'
            ) % (port, discovered_port))

    # Auto-discover services from `suse-library.services[]` (the unified
    # DSL in bundle v0.10+). Each entry has {binding, type, provisioning}
    # and maps to (binding -> type) for the port-forward registration
    # below.
    #
    # An explicit `services={...}` argument disables auto-discovery so a
    # caller can register services the chart doesn't deploy itself, or
    # narrow the surface to a subset.
    #
    # We dropped the pre-DSL legacy path (`suse-library.<chart>.enabled`
    # without `services[]`) when the bundle moved to DSL-only at v0.10.
    # If you're on a bundle <= v0.9, pin the extension to its 0.1.x line
    # or pass `services={...}` explicitly.
    if services == None:
        services = {}
        # Merged view across parsed_values:
        #   - services[] entries come from chart/values.yaml (the user's
        #     DSL) — overlay never has services[].
        #   - chart-level <chart>.enabled comes from the overlay (written
        #     by `rda render` for every enabled local service) OR from
        #     chart/values.yaml on pre-0.1.38 projects that wrote it
        #     manually. Either source counts.
        #
        # Earlier impl looped per-cfg and looked up <chart>.enabled in
        # the SAME cfg as the services[] entry. That broke for the
        # canonical post-0.1.38 split: services[] is in values.yaml,
        # <chart>.enabled is in the overlay, so the check failed for
        # every service and Tilt never registered the workloads. Result:
        # auto-Ingress link never showed up in the UI for grafana /
        # prometheus / etc. Discovered live Apr 30 (issue #14, kind of).
        #
        # The fix: collect services[] and chart-level enabled separately
        # across ALL cfgs, then intersect. Last-wins on binding-name
        # de-dup matches Helm's --values stacking semantics.
        all_lib_blocks = []
        all_services_by_binding = {}
        for i in range(len(parsed_values)):
            cfg = parsed_values[i]
            cfg_path = parsed_values_paths[i]
            lib = (cfg.get('suse-library', {}) or {}) if cfg else {}
            # Always collect lib blocks — `_chart_enabled` below needs
            # to see chart-level `<chart>.enabled` flags written into
            # the overlay by `rda render`.
            all_lib_blocks.append(lib)
            # Services[] DSL is sourced from values.yaml ONLY. The
            # overlay re-projects it with values_mapping applied —
            # which, when a mapping pulls a field through a binding
            # secret, writes `[redacted secret …]` into the projected
            # fields. With last-wins merge the overlay's redacted
            # entries would clobber the clean values.yaml entries
            # here. See `_is_overlay_path` above for the full why.
            if _is_overlay_path(cfg_path):
                continue
            for entry in (lib.get('services') or []):
                if entry.get('binding'):
                    all_services_by_binding[entry['binding']] = entry

        def _chart_enabled(stype, binding=''):
            for lib in all_lib_blocks:
                if (lib.get(stype, {}) or {}).get('enabled'):
                    return True
                # Multi-instance: check aliased block (<type>-<binding>).
                if binding:
                    alias = stype + '-' + binding
                    if (lib.get(alias, {}) or {}).get('enabled'):
                        return True
            return False

        for binding in all_services_by_binding:
            entry = all_services_by_binding[binding]
            stype = entry.get('type')
            provisioning = entry.get('provisioning', '')
            # Only deploy-mode entries register a workload. `local` and
            # `deploy` both deploy in-cluster (legacy + current naming;
            # README documents `deploy`); absent defaults to deploy.
            # `connect` (external instance via binding secret),
            # `shared` and `external` deploy NOTHING — registering a
            # phantom k8s_resource for them fails with "unknown
            # resource", and worse, in connect mode the host template
            # often points at the binding secret which rda's renderer
            # surfaces as `[redacted secret <binding>-binding:host]`,
            # producing the exact symptom we're guarding against.
            if provisioning not in ('', 'local', 'deploy'):
                continue
            # services[].enabled drives deployment (rda-cli v0.1.38+,
            # bundle v0.11.6+). Default true if absent (back-compat with
            # pre-0.1.38 scaffolds; fresh scaffolds opt-in explicitly).
            # When false, the entry is inert: no binding-secret rendered,
            # no chart-level enable flipped by rda render, no sub-chart
            # deployed.
            if entry.get('enabled', True) == False:
                continue
            # Redacted-type guard: services[].type should always be a
            # plain DSL type name (e.g. 'grafana'). If it's an
            # `[redacted secret …]` marker, a bundle bug or a chained
            # value_mapping is routing the type through rda's redactor.
            # Using that string as a chart key produces resources like
            # `<release>-[redacted secret <binding>-binding:type]` —
            # bizarre, unmatchable by k8s_resource, and the Tiltfile
            # aborts loading. Skip cleanly and tell the dev where to
            # look; the underlying sub-chart still renders (or fails
            # loudly at helm time, which is where a values-pipeline bug
            # belongs anyway).
            if type(stype) == "string" and "[redacted" in stype:
                warn(("[suse_rda] skipping services[binding=%r]: type=%r " +
                      "is a redacted secret marker. The DSL type should be " +
                      "a plain string (e.g. 'grafana'). Check the bundle's " +
                      "dsl-mappings.yaml for a values_mapping that routes " +
                      "`services[].type` through a binding secret — that's " +
                      "the layer to fix; the Tiltfile cannot recover a real " +
                      "type from the redacted marker.") % (binding, stype))
                continue
            # Belt-and-braces: at least one cfg must have <chart>.enabled
            # true, otherwise the sub-chart isn't deployed and we'd
            # register a phantom k8s_resource.
            if not _chart_enabled(stype, binding):
                continue
            if stype:
                services[binding] = stype

    # Resolve {{.domain}} from the project's suse-library.domain value.
    _domain_value = ''
    for _cfg in parsed_values:
        _dl = (_cfg.get('suse-library', {}) or {}) if _cfg else {}
        if 'domain' in _dl:
            _domain_value = _dl['domain']

    def _ingress_links(block, ingress_key='ingress'):
        """Extract clickable ingress links from a values block."""
        ing = block.get(ingress_key, {}) if block else {}
        hosts = ing.get('hosts', [])
        if not hosts:
            if not ing.get('enabled'):
                return []
        scheme = 'https' if ing.get('tls') else 'http'
        out = []
        for h in hosts:
            if type(h) == "string":
                host = h
            elif type(h) == "dict":
                host = h.get('host', '')
            else:
                continue
            if not host:
                continue
            # Skip hosts that still contain unresolved Go template
            # syntax (e.g. "app.{{.domain}}"). suse_app() reads
            # values.yaml directly — BEFORE rda render substitutes
            # .domain — so templated placeholders leak into `host`.
            # tilt's link() validates the URL and rejects "{" in the
            # hostname, which fails the whole Tiltfile load. Skipping
            # produces an empty link list rather than a hard crash;
            # the host is still rendered correctly at install time.
            if "{{" in host or "}}" in host:
                continue
            out.append(link(scheme + '://' + host, host))
        return out

    def _suse_lib_block(values_dict, *path):
        block = values_dict.get('suse-library', {}) or {}
        for key in path:
            block = (block.get(key, {}) or {}) if hasattr(block, 'get') else {}
        return block

    if _workloads:
        # ─── Workloads[] mode: per-workload k8s_resource ────────────────
        # Re-read workloads from the fully-merged parsed_values so any
        # overlay values are included (last-wins, matches Helm stacking).
        _merged_workloads = []
        for cfg in parsed_values:
            lib = (cfg.get('suse-library', {}) or {}) if cfg else {}
            wls = lib.get('workloads')
            if wls:
                _merged_workloads = wls
        if not _merged_workloads:
            _merged_workloads = _workloads

        for _wl in _merged_workloads:
            _wl_name = _wl.get('name', 'app')
            _wl_port = _wl.get('port')
            _wl_links = _ingress_links(_wl)
            _resource_name = name + '-' + _wl_name
            if _wl_port:
                # Forward local <port> to Service port 80 (the Service
                # maps 80 → containerPort). Avoids duplicates with
                # Tilt's auto-discovery of Service ports.
                k8s_resource(
                    workload=_resource_name,
                    port_forwards='%d:80' % (_wl_port,),
                    labels=[labels.get(_resource_name, 'app')],
                    links=_wl_links,
                    auto_init=True,
                )
            else:
                k8s_resource(
                    workload=_resource_name,
                    labels=[labels.get(_resource_name, 'app')],
                    links=_wl_links,
                )
    else:
        # ─── Legacy single-workload mode ────────────────────────────────
        app_links = []
        for cfg in parsed_values:
            app_links.extend(_ingress_links(cfg.get('suse-library', {}) or {}))

        k8s_resource(
            workload=name,
            port_forwards='%d:%d' % (port, port),
            labels=[labels.get(name, 'app')],
            links=app_links,
        )

    # Surface each declared service on its conventional port. The
    # workload name is NOT always <release>-<chart-name> — some AppCo
    # charts add a master/replica suffix (redis → <release>-redis-master,
    # prometheus → <release>-prometheus-server, mariadb-galera variants
    # → <release>-mariadb-primary, etc.). The authoritative source of the
    # actual K8s resource name is the `service.host` template in the
    # bundle's library-chart/dsl-mappings.yaml — the same template the
    # library helper uses to build the binding-secret's `host` key.
    # We read that file (vendored at chart_path/charts/suse-library/
    # dsl-mappings.yaml after `helm dep update`), pick the chart-type's
    # entry, render the host template by substituting .Release.Name.
    # Fallback when the file is absent (older bundle) or the type isn't
    # catalogued: the legacy <release>-<service_type> assumption.
    mappings_path = chart_path + '/charts/suse-library/dsl-mappings.yaml'
    mappings_doc = read_yaml(mappings_path, default={'charts': {}})
    catalogued_charts = mappings_doc.get('charts', {})

    def workload_name_for(release, chart_alias, service_type):
        """Compute the rendered K8s workload name for a chart alias.

        For single-instance types, chart_alias == service_type (backward compat).
        For multi-instance types, chart_alias == <type>-<binding> and the
        host template is adjusted accordingly.

        For operator-managed types (e.g. cnpg), the `service.host` template
        points at a Service that is created at RUNTIME by the operator
        once the CR is reconciled (e.g. `<release>-cnpg-rw`). That name is
        NOT in the helm-rendered manifest, so registering it with
        k8s_resource() fails with "unknown resource". Instead, when the
        mapping declares `operator_managed: true`, use `operator_resource`
        — the chart-rendered operator/cluster handle that Tilt CAN see.
        """
        chart_entry = catalogued_charts.get(service_type, {})
        versions = chart_entry.get('versions', [])
        if not versions:
            return release + '-' + chart_alias
        ver = versions[0]
        if ver.get('operator_managed', False):
            op_tpl = ver.get('operator_resource', '')
            if op_tpl:
                if chart_alias != service_type:
                    op_tpl = op_tpl.replace('-' + service_type, '-' + chart_alias, 1)
                return op_tpl.replace('{{ .Release.Name }}', release).replace('{{.Release.Name}}', release)
        host_tpl = ver.get('service', {}).get('host', '')
        if not host_tpl:
            return release + '-' + chart_alias
        # For multi-instance, replace the type in the host template with the alias.
        if chart_alias != service_type:
            host_tpl = host_tpl.replace('-' + service_type + '.', '-' + chart_alias + '.', 1)
        rendered = host_tpl.replace('{{ .Release.Name }}', release).replace('{{.Release.Name}}', release)
        if '.' in rendered:
            rendered = rendered.split('.', 1)[0]
        return rendered

    # Compute chart aliases for multi-instance support (#24).
    # Same convention as the CLI: single-instance types keep the bare type,
    # multi-instance types get <type>-<binding> for ALL instances.
    type_counts = {}
    for binding_name, service_type in services.items():
        type_counts[service_type] = type_counts.get(service_type, 0) + 1

    aliases = {}  # binding → chart_alias
    for binding_name, service_type in services.items():
        if type_counts[service_type] == 1:
            aliases[binding_name] = service_type
        else:
            aliases[binding_name] = service_type + '-' + binding_name

    # Register CRD kinds for operator-managed charts so Tilt
    # recognises them as claimable objects in k8s_resource(objects=...).
    _registered_kinds = {}
    for _stype in services.values():
        _ce = catalogued_charts.get(_stype, {})
        _cvs = _ce.get('versions', [])
        if _cvs and _cvs[0].get('operator_managed'):
            _cr_kind_info = _cvs[0].get('cr_kind', {})
            if _cr_kind_info:
                _kind_key = _cr_kind_info.get('kind', '')
                _api_ver = _cr_kind_info.get('api_version', '')
                if _kind_key and _kind_key not in _registered_kinds:
                    k8s_kind(_kind_key, api_version=_api_ver, pod_readiness='wait')
                    _registered_kinds[_kind_key] = True

    def _bad_workload_name(s):
        """True if a computed workload name is unsafe to pass to k8s_resource.

        Catches three failure shapes we've actually hit:
          - empty / whitespace
          - unresolved Helm template tokens ("{{") — dsl-mappings entry
            referenced a value the Tiltfile can't substitute (e.g.
            `{{ .Values.<binding>.host }}`)
          - rda's redacted-secret marker ("[redacted secret ...]") —
            seen when the host template points at a binding-secret key
            in connect mode and the rendered manifest leaks the marker
            into a resource name. Registering a k8s_resource for such a
            name fails with `unknown resource` and aborts the Tiltfile.

        Skipping registration is strictly safer than aborting: Tilt will
        still auto-discover the actual workload by its real name from
        the manifest stream, just without our port-forward/labels overlay.
        """
        if not s or not s.strip():
            return True
        if '{{' in s or '}}' in s:
            return True
        if '[redacted' in s or 'redacted secret' in s:
            return True
        return False

    used_local_ports = {}
    for binding_name, service_type in services.items():
        chart_alias = aliases[binding_name]
        workload = workload_name_for(name, chart_alias, service_type)
        if _bad_workload_name(workload):
            warn(('[suse_rda] skipping k8s_resource for binding %r ' +
                  '(type=%r): computed workload name %r is not a valid ' +
                  'k8s resource name. This usually means dsl-mappings.yaml ' +
                  'has a host/cr_object template that references a value ' +
                  'the Tiltfile cannot resolve (e.g. a binding-secret key ' +
                  'in `provisioning: connect` mode). Set provisioning ' +
                  'explicitly if you meant to deploy in-cluster, or ignore ' +
                  'this warning if Tilt auto-discovers the workload.') %
                 (binding_name, service_type, workload))
            continue

        # Sub-chart ingress lookup. Use chart_alias for values lookup
        # (multi-instance values are keyed by alias, not bare type).
        svc_port = 0
        chart_entry = catalogued_charts.get(service_type, {})
        chart_versions = chart_entry.get('versions', [])

        # Derive ingress_path from values_mapping['ingress.enabled'].
        # e.g. 'minio.consoleIngress.enabled' -> ['consoleIngress']
        #      'prometheus.server.ingress.enabled' -> ['server', 'ingress']
        #      'grafana.ingress.enabled' -> ['ingress']
        # Segments: drop first (chart name) and last ('enabled') to get path within chart block.
        _ingress_vm = (chart_versions[0].get('values_mapping', {}) or {}).get('ingress.enabled', '') if chart_versions else ''
        if _ingress_vm:
            _segs = _ingress_vm.split('.')
            ingress_path = _segs[1:-1] if len(_segs) > 2 else ['ingress']
        else:
            ingress_path = ['ingress']
        svc_links = []
        for cfg in parsed_values:
            parent = _suse_lib_block(cfg, chart_alias, *ingress_path[:-1])
            svc_links.extend(_ingress_links(parent, ingress_path[-1]))
        is_operator_managed = False
        pod_selector = {}
        cr_object = ''
        operator_resource = ''
        if chart_versions:
            svc_spec = chart_versions[0].get('service', {})
            svc_port = svc_spec.get('port', 0)
            is_operator_managed = chart_versions[0].get('operator_managed', False)
            raw_selector = chart_versions[0].get('pod_selector', {})
            for sel_k, sel_v in raw_selector.items():
                pod_selector[sel_k] = sel_v.replace('{{ .Release.Name }}', name).replace('{{.Release.Name}}', name)
            raw_cr = chart_versions[0].get('cr_object', '')
            if raw_cr:
                cr_object = raw_cr.replace('{{ .Release.Name }}', name).replace('{{.Release.Name}}', name)
            raw_op = chart_versions[0].get('operator_resource', '')
            if raw_op:
                operator_resource = raw_op.replace('{{ .Release.Name }}', name).replace('{{.Release.Name}}', name)
            # Multi-port: find the primary port
            if not svc_port and svc_spec.get('ports'):
                for pname, pspec in svc_spec['ports'].items():
                    if pspec.get('primary', False):
                        svc_port = pspec.get('port', 0)
                        break
                # No primary? Take the first one.
                if not svc_port:
                    for pname, pspec in svc_spec['ports'].items():
                        svc_port = pspec.get('port', 0)
                        break

        if is_operator_managed and cr_object:
            # Operator-managed charts (e.g. CNPG): k8s_kind() registered
            # the CRD kind above, so Tilt auto-discovers the CR as a
            # workload. Keep its discovered name (cr_name) — do NOT
            # rename to the DSL workload name, because that name is
            # already taken by the operator's auto-discovered Deployment
            # (e.g. app-cloudnative-pg). Attach operator-created pods
            # via label selectors.
            cr_name = cr_object.split(':')[0]
            if _bad_workload_name(cr_name):
                warn(('[suse_rda] skipping k8s_resource for operator CR ' +
                      'of binding %r (type=%r): computed cr_name %r is ' +
                      'not a valid k8s resource name. The CRD entry in ' +
                      'dsl-mappings.yaml has a `cr_object` template the ' +
                      'Tiltfile cannot resolve.') %
                     (binding_name, service_type, cr_name))
                continue
            resource_kwargs = {
                'workload': cr_name,
                'labels': [labels.get(workload, 'services')],
                'links': svc_links,
            }
            if pod_selector:
                resource_kwargs['extra_pod_selectors'] = [pod_selector]
            if operator_resource:
                resource_kwargs['resource_deps'] = [operator_resource]
            if svc_port:
                local_port = svc_port
                if local_port < 1024:
                    local_port = svc_port + 10000
                while local_port in used_local_ports:
                    local_port += 1
                used_local_ports[local_port] = True
                resource_kwargs['port_forwards'] = '%d:%d' % (local_port, svc_port)
            k8s_resource(**resource_kwargs)
        elif svc_port:
            local_port = svc_port
            if local_port < 1024:
                local_port = svc_port + 10000
            while local_port in used_local_ports:
                local_port += 1
            used_local_ports[local_port] = True
            k8s_resource(
                workload=workload,
                port_forwards='%d:%d' % (local_port, svc_port),
                labels=[labels.get(workload, 'services')],
                links=svc_links,
            )
        else:
            k8s_resource(
                workload=workload,
                labels=[labels.get(workload, 'services')],
                links=svc_links,
            )


# ─── helm_rda_chart() — helm-rda plugin integration (rda-cli v0.2.0+) ──
#
# Thin chart-rendering primitive that uses the helm-rda plugin's
# `helm rda template` (DSL projection + helm template in one shell call,
# no values.generated.yaml on disk) when available, and falls back to
# `rda render` + Tilt's helm() builtin when not.
#
# Usage in a project Tiltfile:
#
#   load('ext://suse-rda', 'helm_rda_chart')
#   helm_rda_chart(name='my-app', stage='dev')
#   k8s_resource('my-app', port_forwards='8080:8080')
#
# Unlike suse_app(), helm_rda_chart() does NOT do pack build, helm dep
# update, namespace creation, port-forwarding, or pull-secret mirror —
# it's the chart-rendering step only. Compose with k8s_resource() for
# port-forwards. For the batteries-included experience, stick with
# suse_app(); for projects already on rda-cli v0.2.0+ that want the
# plugin's one-step flow without the legacy machinery, this is the hook.

def _check_ingress_conflicts(chart_path, values_files, namespace):
    """Warn if any ingress hostname is already claimed by another namespace."""
    hosts = []
    for vfile in values_files:
        vals = read_yaml(vfile, default={})
        sl = vals.get('suse-library', {})
        domain = sl.get('domain', '')
        for svc in sl.get('services', []):
            if not svc.get('enabled', False):
                continue
            ing = svc.get('ingress', {})
            svc_hosts = ing.get('hosts', [])
            if ing.get('host'):
                svc_hosts = svc_hosts + [ing['host']]
            for h in svc_hosts:
                h = h.replace('{{.domain}}', domain)
                if h:
                    hosts.append(h)
    if not hosts:
        return
    out = str(local(
        'kubectl get ingress --all-namespaces -o ' +
        "jsonpath='{range .items[*]}{.metadata.namespace} {.spec.rules[*].host}{\"\\n\"}{end}' " +
        '2>/dev/null || true',
        quiet=True, echo_off=True,
    )).strip()
    for line in out.split('\n'):
        parts = line.strip().split(' ', 1)
        if len(parts) < 2:
            continue
        ing_ns, ing_host = parts[0], parts[1]
        if ing_ns == namespace:
            continue
        for h in hosts:
            if h == ing_host:
                warn(
                    ('[suse_rda] INGRESS CONFLICT: hostname %s is already claimed ' +
                     'by namespace %s — Traefik will route to the wrong service! ' +
                     'Fix: kubectl delete ingress -n %s -l app.kubernetes.io/instance ' +
                     'or tilt down the other project first.') % (h, ing_ns, ing_ns))


def _helm_rda_plugin_present():
    """True iff `helm plugin list` reports a plugin named 'rda'."""
    out = str(local(
        "helm plugin list 2>/dev/null | grep -qE '^rda[[:space:]]' && " +
        "echo yes || echo no",
        quiet=True, echo_off=True,
    )).strip()
    return out == 'yes'


def helm_rda_chart(
        name,
        chart_path=None,
        stage=None,
        values=None,
        namespace=None,
        set=[]):
    """Render a Helm chart with `helm rda template` and apply the result.

    Detects the helm-rda plugin (rda-cli v0.2.0+); when present, runs
    `helm rda template` directly — DSL projection and `helm template`
    happen in one shell call, no intermediate file on disk. When the
    plugin is absent, falls back to running `rda render` and then
    Tilt's helm() builtin, with a one-line warning so the dev knows to
    install the plugin for the faster path.

    Args:
        name (str): Helm release name.
        chart_path (str|None): path to the Helm chart relative to the
            Tiltfile. Default: auto-detected — prefers `deploy/` (bundle
            v0.11.13+ scaffolds), falls back to `chart/`.
        stage (str|None): rda stage (e.g. 'dev', 'staging'). Passed to
            `helm rda template --stage`. When None, the plugin uses its
            own default (typically the project's current `.rda/stage`).
        values (list[str]|None): values files passed to helm (-f).
            Default [chart_path + '/values.yaml'].
        namespace (str|None): target Kubernetes namespace. Default:
            helm's default. Pass an explicit value to land the release
            in a project-scoped namespace.
        set (list[str]): inline value overrides (helm --set). E.g.
            ['image.tag=v2.3.1', 'replicaCount=3'].
    """
    if chart_path == None:
        if os.path.exists('deploy/Chart.yaml'):
            chart_path = 'deploy'
        elif os.path.exists('chart/Chart.yaml'):
            chart_path = 'chart'
        else:
            chart_path = 'chart'

    if values == None:
        values = [chart_path + '/values.yaml']

    # Stage auto-detection for the fallback path (same logic as suse_app).
    if stage == None:
        _fb_stage = os.getenv('RDA_STAGE', '')
        if not _fb_stage:
            _fb_stage_file = os.path.join(chart_path, '..', '.rda', 'stage')
            if os.path.exists(_fb_stage_file):
                _fb_stage = str(read_file(_fb_stage_file)).strip()
        if not _fb_stage:
            _fb_stage = 'dev'
        stage = _fb_stage

    if _helm_rda_plugin_present():
        # Plugin path: one shell call. `helm rda template` does the DSL
        # projection AND `helm template` — no values.generated.yaml on
        # disk for Tilt to garbage-collect.
        args = ['helm', 'rda', 'template', name, chart_path]
        if namespace:
            args.extend(['--namespace', namespace])
        if stage:
            args.extend(['--stage', stage])
        for vfile in values:
            args.extend(['-f', vfile])
        for kv in set:
            args.extend(['--set', kv])
        k8s_yaml(local(' '.join(args), quiet=True, echo_off=True))
        return

    # Fallback: helm-rda plugin absent. Run `rda render` (writes
    # chart/.rda/values.generated.yaml) then layer the overlay onto the
    # user's values list before handing off to Tilt's helm() builtin.
    rda_present = str(local(
        'command -v rda > /dev/null 2>&1 && echo yes || echo no',
        quiet=True, echo_off=True,
    )).strip()
    if rda_present == 'yes':
        print('helm_rda_chart: helm-rda plugin not installed; falling back ' +
              'to `rda render` + helm template. Install the plugin for the ' +
              'one-step flow (rda-cli v0.2.0+).')
        local('rda render --stage %s' % stage, quiet=True, echo_off=False)
        overlay = chart_path + '/.rda/values.generated.yaml'
        if os.path.exists(overlay) and overlay not in values:
            values = values + [overlay]
    else:
        print('helm_rda_chart: warning — neither the helm-rda plugin nor ' +
              'the `rda` CLI is on PATH. The chart will render without DSL ' +
              'projection; sub-chart values from suse-library.services[] ' +
              'will not reach their targets. Install rda-cli v0.2.0+.')

    k8s_yaml(helm(
        chart_path,
        name=name,
        namespace=namespace or '',
        values=values,
        set=set,
    ))
