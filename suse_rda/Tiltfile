# tilt-extension-suse-rda — suse_app() helper.
#
# Wraps Cloud Native Buildpacks (via `pack`), Helm install, and service
# port-forwarding into a single declarative call. Designed for projects
# scaffolded by `rda new` from a SUSE Rancher Developer Access opinion
# bundle, but usable from any Tiltfile that wants the same conventions.
#
# Usage in a project's Tiltfile:
#
#   load_dynamic('https://raw.githubusercontent.com/idefxH/tilt-extension-suse-rda/main/Tiltfile')
#   suse_app(
#       name='payment-service',
#       language='nodejs',
#       port=8080,
#       services={'database': 'postgresql'},
#   )
#
# That replaces ~30 lines of docker_build / helm / k8s_resource boilerplate
# with one call. Override builder_image when SUSE-AppCo buildpacks ship.

# Heroku CNB builder. Multi-arch (linux/amd64 + linux/arm64) so the
# buildpack inner loop runs natively on Apple Silicon — no Rosetta, no
# binfmt_misc shenanigans, no /usr/bin/env: 'node': No such file or
# directory at the npm-install step.
#
# Why not Paketo: paketobuildpacks/builder-* are amd64-only as of
# 2026-04-27. Running them on arm64 hosts forces the lifecycle through
# Rosetta inside Rancher Desktop's containerd VM, where binfmt_misc
# handler resolution is unreliable for nested execve in pack's
# ephemeral-lifecycle container. Reproduces with every Paketo tag we
# tested (jammy-base, jammy-full, all versions). Net: not actionable on
# our side until Paketo or AppCo publishes an arm64 builder. Tracked in
# tilt-extension-suse-rda#1 for the AppCo migration.
#
# Heroku 24 series: builder ~400MB (vs Paketo full 1.5GB), ships
# heroku/nodejs (active, v5.5.8 on 2026-04-16), heroku/python,
# heroku/go, heroku/java, heroku/ruby. Run image: heroku/heroku:24.
DEFAULT_BUILDER = 'heroku/builder:24'

# Per-language defaults. Live-update paths follow each buildpack's
# expected workspace layout. Languages requiring a full rebuild on every
# change (compiled) leave live_update_paths empty — Tilt rebuilds via
# pack on file change, with Paketo's layer cache providing the speed-up.
LANGUAGE_DEFAULTS = {
    'nodejs': {
        # heroku/nodejs in v5+ is a unified single buildpack that handles
        # engine resolution + npm install internally. The previous
        # sub-buildpacks are deprecated in v5.
        # Requires a committed package-lock.json so heroku/nodejs runs
        # npm ci (the bundle template ships one).
        # heroku/procfile reads ./Procfile to register processes —
        # 'web' for prod, 'dev' for tilt builds (nodemon -L src/index.js).
        'buildpacks': ['heroku/nodejs', 'heroku/procfile'],
        'live_update_paths': ['./src'],
        'live_update_install_trigger': ['./package.json', './package-lock.json'],
        'live_update_install_cmd': 'cd /workspace && npm install --production=false',
        # Tilt builds run the 'dev' process (nodemon -L src/index.js).
        # nodemon polls every 1s — robust against containerd/overlayfs
        # inotify quirks that break node --watch in some k8s setups.
        # Production builds (no --default-process flag) default to 'web'.
        'pack_default_process': 'dev',
        # Force NODE_ENV=development at build so heroku/nodejs runs
        # 'npm ci' instead of 'npm ci --omit=dev' and includes nodemon
        # (which is in devDependencies of the template package.json).
        'pack_build_env': {'NODE_ENV': 'development'},
    },
    'python': {
        'buildpacks': ['heroku/python'],
        'live_update_paths': ['./src'],
        'live_update_install_trigger': ['./requirements.txt', './pyproject.toml', './Pipfile'],
        'live_update_install_cmd': 'cd /workspace && pip install -r requirements.txt 2>/dev/null || true',
    },
    'java': {
        'buildpacks': ['heroku/java'],
        'live_update_paths': [],
        'live_update_install_trigger': [],
        'live_update_install_cmd': None,
    },
    'go': {
        'buildpacks': ['heroku/go'],
        'live_update_paths': [],
        'live_update_install_trigger': [],
        'live_update_install_cmd': None,
    },
}

# Conventional ports for service types declared in `services`. Used by
# port_forwards so a developer can `psql -h localhost -p 5432`, etc.
SERVICE_PORTS = {
    'postgresql': 5432,
    'redis': 6379,
    'mysql': 3306,
    'mongodb': 27017,
    'kafka': 9092,
    'rabbitmq': 5672,
    'nats': 4222,
}


def suse_app(
        name,
        language,
        port=8080,
        services={},
        chart_path='chart',
        chart_values_files=None,
        builder_image=None,
        extra_buildpacks=[],
        additional_env={},
        live_update_paths=None,
        ui_labels=None):
    """Build a project image with pack, deploy its Helm chart, and surface
    convenient port-forwards for the app and any declared services.

    Required:
        name (str): project name. Must equal the Helm release name and the
            chart's metadata.name (so the Deployment resource name matches).
        language (str): one of 'nodejs', 'python', 'java', 'go'. Drives the
            default buildpacks and live-update behaviour.

    Common:
        port (int): HTTP port exposed by the app container. Default 8080.
        services (dict): map of service binding name -> service type. The
            service type must be one of SERVICE_PORTS keys to get a default
            port-forward; unknown types still get a workload entry but no
            port-forward. Example: {'database': 'postgresql'}.
        chart_path (str): path to the Helm chart relative to the Tiltfile.
            Default '.' (current directory).
        chart_values_files (list[str]): values files passed to helm. Default
            [chart_path + '/values.yaml'] (so values.yaml is resolved inside
            the chart directory). Override with paths relative to the Tiltfile
            if your project keeps values somewhere else.

    Override:
        builder_image (str): CNB builder image. Default Paketo full builder.
            Override when SUSE-AppCo buildpacks ship:
            builder_image='registry.suse.com/rda/builder:latest'.
        extra_buildpacks (list[str]): additional CNB buildpacks appended to
            the language defaults. Useful for the future SUSE OTel buildpack
            or a service-binding buildpack.
        additional_env (dict): build-time env vars passed via `pack build --env`.
            E.g. {'BP_NODE_VERSION': '22'}.
        live_update_paths (list[str]): override default sync paths. Pass an
            empty list to disable live_update entirely.
        ui_labels (dict): map of resource name -> Tilt UI label. Defaults
            map the app to 'app', services to 'services'.
    """
    if language not in LANGUAGE_DEFAULTS:
        fail('suse_app: unsupported language %r. Supported: %s' % (
            language, ', '.join(sorted(LANGUAGE_DEFAULTS.keys()))))

    defaults = LANGUAGE_DEFAULTS[language]
    builder = builder_image or DEFAULT_BUILDER
    buildpacks = defaults['buildpacks'] + extra_buildpacks
    sync_paths = live_update_paths if live_update_paths != None else defaults['live_update_paths']
    labels = ui_labels or {}

    # Build pack command. Tilt's $EXPECTED_REF is substituted at build time.
    pack_args = ['pack', 'build', '$EXPECTED_REF', '--builder', builder]
    for bp in buildpacks:
        pack_args.extend(['--buildpack', bp])
    for k, v in additional_env.items():
        pack_args.extend(['--env', '%s=%s' % (k, v)])
    # Per-language opt-in: select the Procfile's dev process so the CNB
    # launcher runs e.g. 'node --watch src/index.js'. The runtime then
    # re-execs itself on each Tilt sync without restart_container().
    dev_proc = defaults.get('pack_default_process')
    if dev_proc:
        pack_args.extend(['--default-process', dev_proc])
    # Per-language build-time env vars (e.g. NODE_ENV=development to
    # force npm ci to include devDependencies, so dev tools like
    # nodemon make it into the image).
    for k, v in (defaults.get('pack_build_env') or {}).items():
        pack_args.extend(['--env', '%s=%s' % (k, v)])
    pack_args.extend(['--path', '.'])
    pack_cmd = ' '.join(pack_args)

    # Live update steps. Only interpreted languages (nodejs, python) opt
    # into live_update; compiled languages rebuild via pack on each change.
    # The cycle is:
    #   1. sync changed files host -> /workspace/ in the running container
    #   2. (optional) reinstall step if its trigger fires (e.g. package.json)
    # The container's process is launched via the Procfile's 'dev' entry
    # (pack --default-process dev) which uses the language's native
    # watcher (node --watch / uvicorn --reload / etc.) so no Tilt-side
    # restart is needed. The Procfile's 'web' entry stays the production
    # launch.
    live_update_steps = []
    for path in sync_paths:
        # CNB launchers (Heroku, Paketo) lay out source at /workspace.
        sync_target = '/workspace/' + path.lstrip('./')
        live_update_steps.append(sync(path, sync_target))
    install_cmd = defaults.get('live_update_install_cmd')
    install_trigger = defaults.get('live_update_install_trigger', [])
    if install_cmd and install_trigger:
        live_update_steps.append(run(install_cmd, trigger=install_trigger))
    # No restart_container() — we rely on the language's own watcher
    # (node --watch, uvicorn --reload, ...) selected via pack_default_process
    # in LANGUAGE_DEFAULTS. The CNB image's launcher runs the dev process
    # which keeps an eye on /workspace/src/ and re-execs itself after each
    # sync, sub-2s reload without Tilt's deprecated container restart.
    # Languages whose runtime has no native watcher fall through to a
    # custom_build rebuild on file change — slower but always correct.

    # Build deps: file paths Tilt watches. Empty sync_paths means "watch the
    # whole project" — rebuild on any change. With sync paths set, Tilt
    # only rebuilds for changes outside those paths (e.g. Chart.yaml, Dockerfile).
    deps = sync_paths if sync_paths else ['.']

    custom_build(
        ref=name + ':dev',
        command=pack_cmd,
        deps=deps,
        live_update=live_update_steps if live_update_steps else None,
    )

    # Helm install. Renders the chart at chart_path with the given values
    # files, applies the resulting manifests to the cluster.
    #
    # Run `helm dependency update` recursively. The parent chart vendors
    # the SUSE library chart at charts/suse-library/, and the library chart
    # itself declares oci:// dependencies on AppCo charts (e.g. postgresql).
    # `helm dep update` is non-recursive — it only pulls deps for the path
    # you pass. We walk charts/*/Chart.yaml first, update each, then update
    # the parent. Without this step the AppCo sub-charts never land in
    # charts/suse-library/charts/ and their resources never get rendered.
    # Requires `helm registry login dp.apps.rancher.io` (one-time, typically
    # wired by the AppCo Rancher Desktop extension).
    # Strategy: only run helm dep update INSIDE vendored sub-chart directories.
    # We skip 'helm dep update' on the parent because:
    #   1. The bundle vendors sub-charts as directories under charts/*. helm
    #      template reads them directly — no parent update needed.
    #   2. Running it on the parent repackages directories into .tgz files
    #      and deletes any unmatched charts/, which interferes with the
    #      recursive dep-update step.
    # If the user introduces a non-vendored top-level dep later, they should
    # vendor it (rda convention) or run helm dep update themselves.
    # Embed the chart-version aligning helper inline. Writing it to
    # /tmp at runtime avoids the path-discovery problem with extensions
    # loaded via ext:// (no __file__ equivalent in Starlark, and
    # read_file() resolves relative to the user's project Tiltfile).
    align_script_path = '/tmp/_suse_rda_align_subchart_versions.py'
    align_script_src = r'''#!/usr/bin/env python3
"""
Align vendored sub-chart Chart.yaml versions with the parent's dep
declarations.

AppCo (and possibly other) Helm charts publish OCI artifact tags that
don't match the chart's internal Chart.yaml version (e.g. tag
"0.4.4-29.1", chart version "0.4.4"). Helm's dep-matching at template
time uses the chart's INTERNAL version, so the alias the parent
declared silently fails to resolve and parent values never reach the
sub-chart. The pulled tgz is correct; we just need to rewrite its
Chart.yaml so the version matches what the parent says.

Usage: align_subchart_versions.py <parent-chart-dir>

Walks <parent>/charts/*.tgz; for each, peeks at Chart.yaml, if its
version differs from what <parent>/Chart.yaml's `dependencies` say for
the same chart name, rewrites the tgz with the aligned version.

Idempotent: skips if already aligned.
"""
import glob
import os
import shutil
import sys
import tarfile

# We import yaml lazily so a missing PyYAML doesn't crash on charts that
# need no patching.
def _yaml():
    try:
        import yaml
        return yaml
    except ImportError:
        sys.stderr.write(
            "[align_subchart_versions] PyYAML not installed; "
            "pip3 install pyyaml or run with python3 -m pip install pyyaml\n"
        )
        sys.exit(0)


def main(parent_dir):
    parent_chart_yaml = os.path.join(parent_dir, "Chart.yaml")
    if not os.path.isfile(parent_chart_yaml):
        return
    yaml = _yaml()
    with open(parent_chart_yaml) as f:
        parent = yaml.safe_load(f) or {}
    deps = parent.get("dependencies") or []
    wanted = {d["name"]: d["version"] for d in deps if "name" in d and "version" in d}
    if not wanted:
        return
    subdir = os.path.join(parent_dir, "charts")
    if not os.path.isdir(subdir):
        return
    fixed = 0
    for tgz in glob.glob(os.path.join(subdir, "*.tgz")):
        work = tgz + ".unpack"
        if os.path.isdir(work):
            shutil.rmtree(work)
        os.makedirs(work)
        try:
            with tarfile.open(tgz, "r:gz") as tf:
                tf.extractall(work, filter='data')  # py3.14+ requires explicit filter for tar safety
            inner = next(
                (d for d in os.listdir(work) if os.path.isdir(os.path.join(work, d))),
                None,
            )
            if not inner:
                continue
            cy_path = os.path.join(work, inner, "Chart.yaml")
            with open(cy_path) as f:
                cy = yaml.safe_load(f) or {}
            name = cy.get("name")
            want = wanted.get(name)
            if want and cy.get("version") != want:
                cy["version"] = want
                with open(cy_path, "w") as f:
                    yaml.safe_dump(cy, f, default_flow_style=False, sort_keys=False)
                new_tgz = tgz + ".new"
                with tarfile.open(new_tgz, "w:gz") as tf:
                    tf.add(os.path.join(work, inner), arcname=inner)
                os.replace(new_tgz, tgz)
                fixed += 1
                print(
                    "[suse_rda] aligned {0} {1} -> {2}".format(name, cy.get("version"), want),
                    flush=True,
                )
        finally:
            if os.path.isdir(work):
                shutil.rmtree(work)
    if fixed:
        print(
            "[suse_rda] patched {0} sub-chart Chart.yaml version(s) under {1}".format(
                fixed, parent_dir
            ),
            flush=True,
        )


if __name__ == "__main__":
    main(sys.argv[1])
'''
    local('cat > ' + align_script_path + " <<'__SUSE_RDA_PY_EOF__'\n" + align_script_src + "\n__SUSE_RDA_PY_EOF__", echo_off=True, quiet=True)

    helm_dep_script = (
        'set -e; ' +
        'if [ -d "' + chart_path + '/charts" ]; then ' +
        '  for sub in "' + chart_path + '"/charts/*/; do ' +
        '    [ -d "$sub" ] || continue; ' +
        '    if [ -f "$sub/Chart.yaml" ] && grep -q "^dependencies:" "$sub/Chart.yaml"; then ' +
        '      echo "[suse_rda] helm dep update $sub"; ' +
        '      helm dependency update "$sub"; ' +
        # AppCo packaging quirk: their Helm charts publish OCI artifact
        # tags like "0.4.4-29.1" but Chart.yaml inside says version
        # "0.4.4". Helm matches deps against the INTERNAL version, so
        # when the library declares postgresql at "0.4.4-29.1" the alias
        # silently fails to resolve at template time and parent values
        # never reach the sub-chart (no app user, no auth db). Patch
        # each pulled sub-chart to align its internal version with what
        # the parent expects. Drop when AppCo aligns version<->tag.
        '      python3 "' + align_script_path + '" "$sub"; ' +
        '    fi; ' +
        '  done; ' +
        'fi'
    )
    local(helm_dep_script, echo_off=True, quiet=False)

    # Ignore helm-managed paths so Tilt doesn't reload-loop. helm dep update
    # writes .tgz files into charts/<sub>/charts/, plus tmpcharts-* dirs and
    # Chart.lock. Tilt watches the project tree by default; without these
    # ignores every helm dep update triggers a reload that re-runs helm dep
    # update -> infinite loop.
    # watch_settings(ignore=...) is GLOBAL — files matched are removed
    # from ALL watch trees including live_update sync. So we keep this
    # list narrow: only the helm-managed dynamic paths that would
    # otherwise cause infinite Tiltfile reload loops on helm dep update
    # output. We do NOT include src/ here even though src/ changes do
    # trigger a Tiltfile reload (because helm() watches chart_path
    # recursively) — ignoring src/ would also stop live_update from
    # syncing src/ into the running container.
    #
    # The Tiltfile reload cost on src/ saves is acceptable because:
    #   - the local() helm dep update / alignment cache via Helm's own
    #     state and complete in <1s when nothing changed
    #   - live_update's sync runs in parallel and the runtime watcher
    #     (nodemon -L for nodejs) still picks up the change
    # If users find the reload too noisy, the longer-term fix is to
    # split the chart into a sub-directory so helm() doesn't watch the
    # app source — out of scope for v0.7.
    watch_settings(ignore=[
        chart_path + '/charts/*/charts',
        chart_path + '/charts/*/tmpcharts-*',
        chart_path + '/charts/*/Chart.lock',
        chart_path + '/Chart.lock',
    ])

    # Default values file follows chart_path. Bundle v0.8+ ships values.yaml
    # under chart/, so when chart_path='chart' the defaults are 'chart/values.yaml'.
    # Users overriding chart_values_files pass paths relative to the Tiltfile.
    if chart_values_files == None:
        chart_values_files = [chart_path + '/values.yaml']

    k8s_yaml(helm(
        chart_path,
        name=name,
        values=chart_values_files,
    ))

    # Surface the application Service on the requested port. Convention:
    # local port == container port, so curl http://localhost:<port> works
    # the same as in production behind an Ingress.
    k8s_resource(
        workload=name,
        port_forwards='%d:%d' % (port, port),
        labels=[labels.get(name, 'app')],
    )

    # Surface each declared service on its conventional port. Workload name
    # follows what the AppCo sub-chart actually deploys: <release>-<alias>,
    # where alias = the binding name the library chart declared (e.g.
    # 'database'). With Helm alias resolution working correctly, the chart
    # renders all its resources prefixed with the alias rather than its own
    # chart name. So services={'database': 'postgresql'} in suse_app() maps
    # to a workload named <release>-database (NOT <release>-postgresql).
    # The service_type is kept as a logical identifier — the binding name
    # is what the K8s API uses.
    for binding_name, service_type in services.items():
        workload = name + '-' + binding_name
        if service_type in SERVICE_PORTS:
            svc_port = SERVICE_PORTS[service_type]
            k8s_resource(
                workload=workload,
                port_forwards='%d:%d' % (svc_port, svc_port),
                labels=[labels.get(workload, 'services')],
            )
        else:
            # Unknown type: register the workload but skip port-forward.
            # The user can add their own k8s_resource call after suse_app()
            # if they need a non-standard port.
            k8s_resource(
                workload=workload,
                labels=[labels.get(workload, 'services')],
            )
