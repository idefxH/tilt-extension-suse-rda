# tilt-extension-suse-rda — suse_app() helper.
#
# Wraps Cloud Native Buildpacks (via `pack`), Helm install, and service
# port-forwarding into a single declarative call. Designed for projects
# scaffolded by `rda new` from a SUSE Rancher Developer Access opinion
# bundle, but usable from any Tiltfile that wants the same conventions.
#
# Usage in a project's Tiltfile:
#
#   load_dynamic('https://raw.githubusercontent.com/idefxH/tilt-extension-suse-rda/main/Tiltfile')
#   suse_app(
#       name='my-app',
#       language='nodejs',
#   )
#
# That replaces ~30 lines of docker_build / helm / k8s_resource boilerplate
# with one call. Service port-forwards are auto-discovered from the
# project's values.yaml (under deploy/ on bundle 0.11.13+ scaffolds, or
# chart/ on older ones — chart_path defaults to auto-detection): every
# `suse-library.services[]` entry (the unified DSL written by `rda
# add-service`) is registered. The app's HTTP port is read from
# `suse-library.port` in the same values.yaml — values.yaml is the source
# of truth, so the Tiltfile stays terse. Override builder_image when
# SUSE-AppCo buildpacks ship.
#
# Pass `services={'<binding>': '<type>'}` explicitly only when you want to
# register a service the chart doesn't deploy itself, or narrow the
# auto-discovered set to a subset.

# Heroku CNB builder. Multi-arch (linux/amd64 + linux/arm64) so the
# buildpack inner loop runs natively on Apple Silicon — no Rosetta, no
# binfmt_misc shenanigans, no /usr/bin/env: 'node': No such file or
# directory at the npm-install step.
#
# Why not Paketo: paketobuildpacks/builder-* are amd64-only as of
# 2026-04-27. Running them on arm64 hosts forces the lifecycle through
# Rosetta inside Rancher Desktop's containerd VM, where binfmt_misc
# handler resolution is unreliable for nested execve in pack's
# ephemeral-lifecycle container. Reproduces with every Paketo tag we
# tested (jammy-base, jammy-full, all versions). Net: not actionable on
# our side until Paketo or AppCo publishes an arm64 builder. Tracked in
# tilt-extension-suse-rda#1 for the AppCo migration.
#
# Heroku 24 series: builder ~400MB (vs Paketo full 1.5GB), ships
# heroku/nodejs (active, v5.5.8 on 2026-04-16), heroku/python,
# heroku/go, heroku/java, heroku/ruby. Run image: heroku/heroku:24.
DEFAULT_BUILDER = 'heroku/builder:24'

# Per-language defaults. Live-update paths follow each buildpack's
# expected workspace layout. Languages requiring a full rebuild on every
# change (compiled) leave live_update_paths empty — Tilt rebuilds via
# pack on file change, with Paketo's layer cache providing the speed-up.
LANGUAGE_DEFAULTS = {
    'nodejs': {
        # heroku/nodejs in v5+ is a unified single buildpack that handles
        # engine resolution + npm install internally. The previous
        # sub-buildpacks are deprecated in v5.
        # Requires a committed package-lock.json so heroku/nodejs runs
        # npm ci (the bundle template ships one).
        # heroku/procfile reads ./Procfile to register processes —
        # 'web' for prod, 'dev' for tilt builds (nodemon -L src/index.js).
        'buildpacks': ['heroku/nodejs', 'heroku/procfile'],
        'live_update_paths': ['./src'],
        'live_update_install_trigger': ['./package.json', './package-lock.json'],
        'live_update_install_cmd': 'cd /workspace && npm install --production=false',
        # Tilt builds run the 'dev' process (nodemon -L src/index.js).
        # nodemon polls every 1s — robust against containerd/overlayfs
        # inotify quirks that break node --watch in some k8s setups.
        # Production builds (no --default-process flag) default to 'web'.
        'pack_default_process': 'dev',
        # Force NODE_ENV=development at build so heroku/nodejs runs
        # 'npm ci' instead of 'npm ci --omit=dev' and includes nodemon
        # (which is in devDependencies of the template package.json).
        'pack_build_env': {'NODE_ENV': 'development'},
    },
    'python': {
        'buildpacks': ['heroku/python'],
        'live_update_paths': ['./src'],
        'live_update_install_trigger': ['./requirements.txt', './pyproject.toml', './Pipfile'],
        'live_update_install_cmd': 'cd /workspace && pip install -r requirements.txt 2>/dev/null || true',
    },
    'java': {
        'buildpacks': ['heroku/java'],
        'live_update_paths': [],
        'live_update_install_trigger': [],
        'live_update_install_cmd': None,
    },
    'go': {
        # heroku/go + heroku/procfile. Go SDK is NOT in the CNB
        # runtime image (heroku/heroku:24), so in-container
        # recompilation (air, go build) is impossible. Every source
        # change triggers a full `pack build` — heroku/go's layer
        # cache keeps rebuilds to ~10-15s after the first one.
        #
        # If a future builder ships Go in the launch image (e.g.
        # SUSE AppCo builder with a `-dev` variant), re-enable
        # live_update_paths and switch dev: to air.
        'buildpacks': ['heroku/go', 'heroku/procfile'],
        'live_update_paths': [],
        'live_update_install_trigger': [],
        'live_update_install_cmd': None,
    },
}

# Conventional ports for service types declared in `services`. Used by
# port_forwards so a developer can `psql -h localhost -p 5432`, etc.
SERVICE_PORTS = {
    'postgresql': 5432,
    'redis': 6379,
    'mysql': 3306,
    'mongodb': 27017,
    'kafka': 9092,
    'rabbitmq': 5672,
    'nats': 4222,
}


def suse_app(
        name,
        language,
        port=None,
        services=None,
        chart_path=None,
        chart_values_files=None,
        builder_image=None,
        extra_buildpacks=[],
        additional_env={},
        live_update_paths=None,
        ui_labels=None):
    """Build a project image with pack, deploy its Helm chart, and surface
    convenient port-forwards for the app and any declared services.

    Required:
        name (str): project name. Must equal the Helm release name and the
            chart's metadata.name (so the Deployment resource name matches).
        language (str): one of 'nodejs', 'python', 'java', 'go'. Drives the
            default buildpacks and live-update behaviour.

    Common:
        port (int|None): HTTP port exposed by the app container. **Default
            None — derived from `suse-library.port` in chart/values.yaml.**
            The library chart already reads `.Values.port` as the
            container's port AND the Service's targetPort, so values.yaml
            is the source of truth. Don't pass this argument unless you
            need to override; if you pass a value that mismatches
            values.yaml, the Tiltfile fails fast (forcing the dev to fix
            the duplication rather than carry two drifting numbers). When
            values.yaml has no `suse-library.port` entry, falls back to
            the library chart's own default of 8080.
        services (dict|None): map of service binding name -> service type. The
            service type must be one of SERVICE_PORTS keys to get a default
            port-forward; unknown types still get a workload entry but no
            port-forward. Example: {'database': 'postgresql'}.
            **When None (default), services are auto-discovered from
            chart_values_files** — every entry in `suse-library.services[]`
            (the unified DSL) and every chart with `suse-library.<chart>.enabled:
            true` (the legacy gate) is registered. This is the recommended
            mode: `rda add-service <type> <binding>` updates values.yaml,
            and Tilt picks up the change on the next reload — nothing in the
            Tiltfile needs to be in lockstep with values.yaml.
            Pass an explicit dict to opt out of auto-discovery (e.g. to
            register a service the chart doesn't deploy itself).
        chart_path (str|None): path to the Helm chart relative to the Tiltfile.
            **Default None — auto-detected.** Prefers 'deploy/' (the new
            convention from bundle 0.11.13+ scaffolds, where the directory
            name signals the directory's purpose: it's what gets deployed
            to Kubernetes). Falls back to 'chart/' for projects scaffolded
            before the rename. Pass a path explicitly to override (e.g.
            'helm/' for a non-scaffold project, or 'chart' to force the
            legacy name during migration).
        chart_values_files (list[str]): values files passed to helm. Default
            [chart_path + '/values.yaml'] (so values.yaml is resolved inside
            the chart directory). Override with paths relative to the Tiltfile
            if your project keeps values somewhere else.

    Override:
        builder_image (str): CNB builder image. Default Paketo full builder.
            Override when SUSE-AppCo buildpacks ship:
            builder_image='registry.suse.com/rda/builder:latest'.
        extra_buildpacks (list[str]): additional CNB buildpacks appended to
            the language defaults. Useful for the future SUSE OTel buildpack
            or a service-binding buildpack.
        additional_env (dict): build-time env vars passed via `pack build --env`.
            E.g. {'BP_NODE_VERSION': '22'}.
        live_update_paths (list[str]): override default sync paths. Pass an
            empty list to disable live_update entirely.
        ui_labels (dict): map of resource name -> Tilt UI label. Defaults
            map the app to 'app', services to 'services'.
    """
    if language not in LANGUAGE_DEFAULTS:
        fail('suse_app: unsupported language %r. Supported: %s' % (
            language, ', '.join(sorted(LANGUAGE_DEFAULTS.keys()))))

    # Auto-detect chart_path when caller didn't pass one. Prefer deploy/
    # (bundle template 0.11.13+ scaffolds) and fall back to chart/ (older
    # scaffolds). Project Tiltfiles that pass chart_path='chart' or
    # chart_path='deploy' explicitly bypass this — explicit always wins.
    # Final fallback to 'chart' for projects with neither directory yet
    # (preserves the historical default so existing tests / fixtures keep
    # working).
    # Note: Tilt's Starlark `os.path` exposes `exists()` but NOT `isdir()`
    # (verified at runtime — the latter raises 'module has no .isdir field
    # or method'). We probe for `<dir>/Chart.yaml` instead, which is a
    # tighter signal anyway: a deploy/ or chart/ that doesn't carry a
    # Chart.yaml is useless to helm regardless of its directory-ness.
    if chart_path == None:
        if os.path.exists('deploy/Chart.yaml'):
            chart_path = 'deploy'
        elif os.path.exists('chart/Chart.yaml'):
            chart_path = 'chart'
        else:
            chart_path = 'chart'

    defaults = LANGUAGE_DEFAULTS[language]
    builder = builder_image or DEFAULT_BUILDER
    buildpacks = defaults['buildpacks'] + extra_buildpacks
    sync_paths = live_update_paths if live_update_paths != None else defaults['live_update_paths']
    labels = ui_labels or {}

    # Build pack command. Tilt's $EXPECTED_REF is substituted at build time.
    pack_args = ['pack', 'build', '$EXPECTED_REF', '--builder', builder]
    for bp in buildpacks:
        pack_args.extend(['--buildpack', bp])
    for k, v in additional_env.items():
        pack_args.extend(['--env', '%s=%s' % (k, v)])
    # Per-language opt-in: select the Procfile's dev process so the CNB
    # launcher runs e.g. 'node --watch src/index.js'. The runtime then
    # re-execs itself on each Tilt sync without restart_container().
    dev_proc = defaults.get('pack_default_process')
    if dev_proc:
        pack_args.extend(['--default-process', dev_proc])
    # Per-language build-time env vars (e.g. NODE_ENV=development to
    # force npm ci to include devDependencies, so dev tools like
    # nodemon make it into the image).
    for k, v in (defaults.get('pack_build_env') or {}).items():
        pack_args.extend(['--env', '%s=%s' % (k, v)])
    pack_args.extend(['--path', '.'])
    pack_cmd = ' '.join(pack_args)

    # Pre-build hook: auto-`go mod tidy` for Go projects with a go.mod
    # but no go.sum (or whose go.sum is older than go.mod, indicating
    # the dev added a require but never re-tidied). The heroku/go
    # buildpack runs `go install` in module-aware strict mode, which
    # fails with `missing go.sum entry for module providing package
    # <pkg>` when go.sum is absent. Auto-tidying bridges:
    #   - Existing projects scaffolded before bundle 0.11.23 ships
    #     go.sum (the template addition that triggered this hook).
    #   - Devs who hand-edit go.mod and forget to re-tidy.
    # Skip silently when:
    #   - language != 'go'
    #   - no go.mod at the project root
    #   - go is not on PATH (dev hasn't installed Go locally — pack
    #     downloads its own Go inside the buildpack image, but tidy
    #     needs a host-side go binary)
    if language == 'go' and os.path.exists('go.mod'):
        local(
            "set -e; " +
            "if ! command -v go >/dev/null 2>&1; then " +
            "echo '[suse_rda] go not on PATH; skipping go mod tidy preflight' >&2; " +
            "exit 0; fi; " +
            "if [ ! -f go.sum ] || [ go.mod -nt go.sum ]; then " +
            "echo '[suse_rda] running go mod tidy (go.sum missing or stale)'; " +
            "go mod tidy; " +
            "fi",
            quiet=False, echo_off=True,
        )

    # Live update steps. Only interpreted languages (nodejs, python) opt
    # into live_update; compiled languages rebuild via pack on each change.
    # The cycle is:
    #   1. sync changed files host -> /workspace/ in the running container
    #   2. (optional) reinstall step if its trigger fires (e.g. package.json)
    # The container's process is launched via the Procfile's 'dev' entry
    # (pack --default-process dev) which uses the language's native
    # watcher (node --watch / uvicorn --reload / etc.) so no Tilt-side
    # restart is needed. The Procfile's 'web' entry stays the production
    # launch.
    live_update_steps = []
    for path in sync_paths:
        # CNB launchers (Heroku, Paketo) lay out source at /workspace.
        sync_target = '/workspace/' + path.lstrip('./')
        live_update_steps.append(sync(path, sync_target))
    install_cmd = defaults.get('live_update_install_cmd')
    install_trigger = defaults.get('live_update_install_trigger', [])
    if install_cmd and install_trigger:
        live_update_steps.append(run(install_cmd, trigger=install_trigger))
    # No restart_container() — we rely on the language's own watcher
    # (node --watch, uvicorn --reload, ...) selected via pack_default_process
    # in LANGUAGE_DEFAULTS. The CNB image's launcher runs the dev process
    # which keeps an eye on /workspace/src/ and re-execs itself after each
    # sync, sub-2s reload without Tilt's deprecated container restart.
    # Languages whose runtime has no native watcher fall through to a
    # custom_build rebuild on file change — slower but always correct.

    # Build deps: file paths Tilt watches. Empty sync_paths means "watch the
    # whole project" — rebuild on any change. With sync paths set, Tilt
    # only rebuilds for changes outside those paths (e.g. Chart.yaml, Dockerfile).
    deps = sync_paths if sync_paths else ['.']

    custom_build(
        ref=name + ':dev',
        command=pack_cmd,
        deps=deps,
        live_update=live_update_steps if live_update_steps else None,
    )

    # Helm install. Renders the chart at chart_path with the given values
    # files, applies the resulting manifests to the cluster.
    #
    # Run `helm dependency update` recursively. The parent chart vendors
    # the SUSE library chart at charts/suse-library/, and the library chart
    # itself declares oci:// dependencies on AppCo charts (e.g. postgresql).
    # `helm dep update` is non-recursive — it only pulls deps for the path
    # you pass. We walk charts/*/Chart.yaml first, update each, then update
    # the parent. Without this step the AppCo sub-charts never land in
    # charts/suse-library/charts/ and their resources never get rendered.
    # Requires `helm registry login dp.apps.rancher.io` (one-time, typically
    # wired by the AppCo Rancher Desktop extension).
    # Strategy: only run helm dep update INSIDE vendored sub-chart directories.
    # We skip 'helm dep update' on the parent because:
    #   1. The bundle vendors sub-charts as directories under charts/*. helm
    #      template reads them directly — no parent update needed.
    #   2. Running it on the parent repackages directories into .tgz files
    #      and deletes any unmatched charts/, which interferes with the
    #      recursive dep-update step.
    # If the user introduces a non-vendored top-level dep later, they should
    # vendor it (rda convention) or run helm dep update themselves.
    # Embed the chart-version aligning helper inline. Writing it to
    # /tmp at runtime avoids the path-discovery problem with extensions
    # loaded via ext:// (no __file__ equivalent in Starlark, and
    # read_file() resolves relative to the user's project Tiltfile).
    align_script_path = '/tmp/_suse_rda_align_subchart_versions.py'
    align_script_src = r'''#!/usr/bin/env python3
"""
Align vendored sub-chart Chart.yaml versions with the parent's dep
declarations.

AppCo (and possibly other) Helm charts publish OCI artifact tags that
don't match the chart's internal Chart.yaml version (e.g. tag
"0.4.4-29.1", chart version "0.4.4"). Helm's dep-matching at template
time uses the chart's INTERNAL version, so the alias the parent
declared silently fails to resolve and parent values never reach the
sub-chart. The pulled tgz is correct; we just need to rewrite its
Chart.yaml so the version matches what the parent says.

Usage: align_subchart_versions.py <parent-chart-dir>

Walks <parent>/charts/*.tgz; for each, peeks at Chart.yaml, if its
version differs from what <parent>/Chart.yaml's `dependencies` say for
the same chart name, rewrites the tgz with the aligned version.

Idempotent: skips if already aligned.
"""
import glob
import os
import shutil
import sys
import tarfile

def _safe_extract(tf, dest):
    # py3.12+ added the `filter` kwarg + the data_filter helper.
    # py<3.12 doesn't accept `filter=` — fall back to the legacy
    # extractall() (no member sanitisation). Acceptable here because
    # the input is a chart .tgz we just downloaded from our own
    # registry and helm dep update validated.
    if hasattr(tarfile, 'data_filter'):
        tf.extractall(dest, filter='data')
    else:
        tf.extractall(dest)



# We import yaml lazily so a missing PyYAML doesn't crash on charts that
# need no patching.
def _yaml():
    try:
        import yaml
        return yaml
    except ImportError:
        sys.stderr.write(
            "[align_subchart_versions] PyYAML not installed; " +
            "pip3 install pyyaml or run with python3 -m pip install pyyaml\n"
        )
        sys.exit(0)


def main(parent_dir):
    parent_chart_yaml = os.path.join(parent_dir, "Chart.yaml")
    if not os.path.isfile(parent_chart_yaml):
        return
    yaml = _yaml()
    with open(parent_chart_yaml) as f:
        parent = yaml.safe_load(f) or {}
    deps = parent.get("dependencies") or []
    wanted = {d["name"]: d["version"] for d in deps if "name" in d and "version" in d}
    if not wanted:
        return
    subdir = os.path.join(parent_dir, "charts")
    if not os.path.isdir(subdir):
        return
    fixed = 0
    for tgz in glob.glob(os.path.join(subdir, "*.tgz")):
        work = tgz + ".unpack"
        if os.path.isdir(work):
            shutil.rmtree(work)
        os.makedirs(work)
        try:
            with tarfile.open(tgz, "r:gz") as tf:
                _safe_extract(tf, work)  # tarfile filter handling — py3.12+ supports `filter='data'`, older python doesn't
            inner = next(
                (d for d in os.listdir(work) if os.path.isdir(os.path.join(work, d))),
                None,
            )
            if not inner:
                continue
            cy_path = os.path.join(work, inner, "Chart.yaml")
            with open(cy_path) as f:
                cy = yaml.safe_load(f) or {}
            name = cy.get("name")
            want = wanted.get(name)
            if want and cy.get("version") != want:
                cy["version"] = want
                with open(cy_path, "w") as f:
                    yaml.safe_dump(cy, f, default_flow_style=False, sort_keys=False)
                new_tgz = tgz + ".new"
                with tarfile.open(new_tgz, "w:gz") as tf:
                    tf.add(os.path.join(work, inner), arcname=inner)
                os.replace(new_tgz, tgz)
                fixed += 1
                print(
                    "[suse_rda] aligned {0} {1} -> {2}".format(name, cy.get("version"), want),
                    flush=True,
                )
        finally:
            if os.path.isdir(work):
                shutil.rmtree(work)
    if fixed:
        print(
            "[suse_rda] patched {0} sub-chart Chart.yaml version(s) under {1}".format(
                fixed, parent_dir
            ),
            flush=True,
        )


if __name__ == "__main__":
    main(sys.argv[1])
'''
    local('cat > ' + align_script_path + " <<'__SUSE_RDA_PY_EOF__'\n" + align_script_src + "\n__SUSE_RDA_PY_EOF__", echo_off=True, quiet=True)

    # Filter the library chart's deps down to ONLY the sub-charts the
    # project has enabled. Without this, every `helm dep update` pulls
    # all 7+ AppCo charts (postgresql, redis, prometheus, grafana, dex,
    # mariadb, apache-kafka, ...) on every fresh project — even when
    # the dev only enabled mariadb. Triggers AppCo rate-limits in
    # high-iteration workflows (e2e harness, repeated `rda new`).
    #
    # The filter reads the project's values + the rda-render overlay,
    # builds the set of `<chart>.enabled: true` chart names, and
    # rewrites the library chart's Chart.yaml keeping only those deps.
    # Backed up to Chart.yaml.full on first run so subsequent
    # enable/disable cycles can re-derive from the full list.
    #
    # Idempotent: if Chart.yaml.full exists, restore from it before
    # filtering. Safe across rda render re-runs (Tilt fires it on
    # every save in the chart tree).
    filter_script_path = '/tmp/_suse_rda_filter_enabled_deps.py'
    filter_script_src = r'''#!/usr/bin/env python3
"""
Strip the library Chart.yaml deps down to only the sub-charts the
project has enabled in its values. Cuts `helm dep update` work to
the minimum (one OCI pull per actually-used sub-chart) and dodges
AppCo rate-limits.

Usage: filter_enabled_deps.py <library-chart-dir> <values-file>...

Reads each values file, walks `suse-library.<chart>.enabled` AND
top-level `<chart>.enabled` (rda render's overlay shape), unions
the truthy chart names, then rewrites <library>/Chart.yaml keeping
only deps whose `name` matches.

Source-of-truth: <library>/Chart.yaml.full. Created on first run
from the live Chart.yaml. Filtering reads from .full every run so
re-enabling a previously-disabled chart still works.

Idempotent. Outputs one line per kept dep + the full count.
"""
import os
import shutil
import sys


def _yaml():
    try:
        import yaml
        return yaml
    except ImportError:
        # Fail loud, NOT silent. If PyYAML is missing the filter cannot
        # run, every helm dep update pulls every catalogued sub-chart,
        # and any HTTP-source repo (e.g. dex on charts.dexidp.io) that
        # isn't in `helm repo list` triggers a confusing `no cached
        # repository for helm-manager-<hash>` error several layers down.
        # Exit 2 so the caller's `|| { ... }` branch fires with a clear
        # remediation pointing the dev at python3 -m pip install pyyaml
        # in the python3 the host's Tilt actually invokes (which on
        # macOS may differ from the conda one in the dev's shell).
        sys.stderr.write(
            ("[filter_enabled_deps] PyYAML not installed in this python3 " +
             "({0}); install with: python3 -m pip install --break-system-packages pyyaml\n" +
             "(check `which python3` from the same env Tilt runs in — on macOS " +
             "the host's /usr/bin/python3 is often distinct from your shell's.)\n"
            ).format(sys.executable)
        )
        sys.exit(2)


def enabled_charts(values_files):
    """Union the chart names with .enabled=true across all values files.

    Three shapes supported:
      1. Static `<chart>.enabled: true` under `suse-library` (legacy).
      2. rda render overlay's `suse-library.<chart>.enabled: true`.
      3. DSL `services[]` entries — `services[i].type` + `enabled: true`
         (the modern path, what `rda add-service` writes). Critical:
         this filter runs BEFORE `rda render` regenerates the overlay,
         so we can't rely on shape #2 alone — services[] is the only
         source of truth at filter-time on a fresh project.

    Top-level `<chart>.enabled` is also checked as a fallback for the
    rare project that pre-dates the DSL.
    """
    yaml = _yaml()
    enabled = set()
    SKIP_TOP = {"suse-library", "global", "image", "ingress",
                "imagePullSecrets", "resources", "probes", "metrics",
                "podAnnotations", "service", "name", "replicas",
                "port", "apiVersion", "kind"}
    for path in values_files:
        if not os.path.isfile(path):
            continue
        try:
            with open(path) as f:
                data = yaml.safe_load(f) or {}
        except Exception:
            continue
        if not isinstance(data, dict):
            continue
        # Shape 1+2: under suse-library.<chart>.enabled
        sl = data.get("suse-library")
        if isinstance(sl, dict):
            for name, sub in sl.items():
                if isinstance(sub, dict) and sub.get("enabled") is True:
                    enabled.add(name)
            # Shape 3: services[] DSL — services[i].type + enabled. The
            # CLI defaults services[].enabled to false in the scaffold,
            # so we only count entries the dev has explicitly flipped to
            # true. Same iteration the library helpers and `rda render`
            # walk; staying consistent here matters.
            services = sl.get("services") or []
            if isinstance(services, list):
                for entry in services:
                    if not isinstance(entry, dict):
                        continue
                    # Default-when-missing: true (back-compat with pre-
                    # 0.1.38 scaffolds that didn't write the field).
                    if entry.get("enabled", True) is False:
                        continue
                    chart_type = entry.get("type")
                    if chart_type:
                        enabled.add(chart_type)
        # Top-level fallback (legacy / non-DSL projects).
        for name, sub in data.items():
            if name in SKIP_TOP:
                continue
            if isinstance(sub, dict) and sub.get("enabled") is True:
                enabled.add(name)
    return enabled


def main(library_dir, *values_files):
    chart_yaml = os.path.join(library_dir, "Chart.yaml")
    full_backup = chart_yaml + ".full"
    if not os.path.isfile(chart_yaml):
        return

    # First run: snapshot the live Chart.yaml as the source-of-truth.
    if not os.path.isfile(full_backup):
        shutil.copy2(chart_yaml, full_backup)

    yaml = _yaml()
    with open(full_backup) as f:
        full = yaml.safe_load(f) or {}

    full_deps = full.get("dependencies") or []
    if not full_deps:
        return  # nothing to filter

    enabled = enabled_charts(values_files)
    if not enabled:
        # No services enabled. Strip ALL deps — fastest possible
        # `helm dep update`, which becomes a no-op.
        kept = []
    else:
        # Compare against the user-facing chart key, which is the helm
        # `alias` when present (so `dex-idp` aliased as `dex` matches
        # services[].type=dex), or the bare `name` otherwise. Without
        # this, aliased deps get stripped silently and the user sees
        # `unknown resource <release>-<binding>` when the tilt-ext
        # tries to wire a k8s_resource that helm never rendered.
        kept = [d for d in full_deps if d.get("alias", d.get("name")) in enabled]

    out = dict(full)  # shallow copy
    out["dependencies"] = kept

    new_content = yaml.safe_dump(out, default_flow_style=False, sort_keys=False)
    # IDEMPOTENT WRITE: only touch Chart.yaml if the content actually
    # differs. Without this guard, Tilt sees Chart.yaml change every
    # reload (because we always rewrite), reloads the Tiltfile (the chart
    # tree is in its watch set), which re-runs this script, which writes
    # again — infinite loop. Tilt's fast-path
    # `Chart.lock newer than Chart.yaml` also never triggers because
    # we keep bumping Chart.yaml's mtime. See tilt-extension #URGENT.
    try:
        with open(chart_yaml) as f:
            cur_content = f.read()
    except OSError:
        cur_content = None
    wrote = (cur_content != new_content)
    if wrote:
        with open(chart_yaml, "w") as f:
            f.write(new_content)

    skipped = len(full_deps) - len(kept)
    suffix = "" if wrote else " (unchanged on disk)"
    print(
        ("[suse_rda] filter_enabled_deps: kept {0}/{1} sub-chart(s) " +
         "[{2}]; skipped {3} disabled{4}").format(
            len(kept), len(full_deps),
            ", ".join(sorted([d.get("name", "?") for d in kept])) or "none",
            skipped, suffix,
        ),
        flush=True,
    )


if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("usage: filter_enabled_deps.py <library-chart-dir> <values-file>...",
              file=sys.stderr)
        sys.exit(2)
    main(*sys.argv[1:])
'''
    local('cat > ' + filter_script_path + " <<'__SUSE_RDA_PY_EOF__'\n" + filter_script_src + "\n__SUSE_RDA_PY_EOF__", echo_off=True, quiet=True)

    # Pre-flight helper: ensure every non-OCI repo URL referenced by the
    # library Chart.yaml is registered with `helm repo add` BEFORE
    # `helm dep update --skip-refresh` runs. Without this, the first
    # `tilt up` of any project that vendors a library with a fresh HTTP
    # source (e.g. dex on charts.dexidp.io) crashes with a confusing
    #   `Error: no cached repository for helm-manager-<sha>`
    # because `--skip-refresh` forbids the on-the-fly index fetch.
    #
    # OCI repos (oci://dp.apps.rancher.io/charts) are skipped — Helm
    # talks to them directly without an index cache.
    bootstrap_repos_script_path = '/tmp/_suse_rda_bootstrap_helm_repos.py'
    bootstrap_repos_script_src = r'''#!/usr/bin/env python3
"""
Walk a library chart's Chart.yaml.full (or Chart.yaml as fallback) and
ensure every HTTP/HTTPS repository: URL is registered with helm. We
read .full because filter_enabled_deps strips Chart.yaml down to the
enabled subset — but a previously-disabled chart on an HTTP repo could
get re-enabled later, and we want the index ready when it does.

OCI repos are skipped (Helm doesn't cache an index for them).
Idempotent: helm repo add fails when a name+url is already registered;
we tolerate that.

Usage: bootstrap_helm_repos.py <library-chart-dir>
"""
import hashlib
import os
import re
import subprocess
import sys


def _yaml():
    try:
        import yaml
        return yaml
    except ImportError:
        sys.stderr.write(
            ("[bootstrap_helm_repos] PyYAML not installed in this python3 " +
             "({0}); install with: python3 -m pip install --break-system-packages pyyaml\n"
            ).format(sys.executable)
        )
        sys.exit(2)


def _existing_repo_urls():
    try:
        out = subprocess.check_output(
            ["helm", "repo", "list", "-o", "yaml"],
            stderr=subprocess.DEVNULL,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return set()
    yaml = _yaml()
    data = yaml.safe_load(out) or []
    return {(item.get("name"), item.get("url")) for item in data if isinstance(item, dict)}


def _safe_name_for_url(url):
    # Helm repo names are short ascii. Use a slugified host + 6-char hash
    # so reruns produce the same name and `helm repo add` is idempotent.
    host = re.sub(r"^https?://", "", url).split("/")[0]
    slug = re.sub(r"[^a-z0-9]+", "-", host.lower()).strip("-") or "repo"
    short = hashlib.sha256(url.encode()).hexdigest()[:6]
    return "rda-{0}-{1}".format(slug, short)


def main(library_dir):
    chart_yaml = os.path.join(library_dir, "Chart.yaml.full")
    if not os.path.isfile(chart_yaml):
        chart_yaml = os.path.join(library_dir, "Chart.yaml")
    if not os.path.isfile(chart_yaml):
        return
    yaml = _yaml()
    with open(chart_yaml) as f:
        doc = yaml.safe_load(f) or {}
    deps = doc.get("dependencies") or []
    http_urls = sorted({
        d.get("repository", "").strip()
        for d in deps if isinstance(d, dict)
        and isinstance(d.get("repository"), str)
        and d["repository"].startswith(("http://", "https://"))
    })
    if not http_urls:
        return
    existing = _existing_repo_urls()
    existing_urls = {url for _, url in existing}
    added = []
    for url in http_urls:
        if url in existing_urls:
            continue
        name = _safe_name_for_url(url)
        try:
            subprocess.check_call(
                ["helm", "repo", "add", name, url],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.STDOUT,
            )
            added.append((name, url))
        except subprocess.CalledProcessError:
            # Likely already registered under a different name — fine,
            # let the subsequent --skip-refresh step succeed regardless.
            pass
    if added:
        print(
            "[suse_rda] bootstrapped {0} HTTP helm repo(s): {1}".format(
                len(added), ", ".join(u for _, u in added)
            ),
            flush=True,
        )
        # The added repos have no cached index yet; refresh just them.
        # `helm repo update <names>` is the targeted form (3.13+).
        try:
            subprocess.check_call(
                ["helm", "repo", "update"] + [n for n, _ in added],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.STDOUT,
            )
        except subprocess.CalledProcessError:
            # Older helm: untargeted update is the fallback.
            subprocess.call(["helm", "repo", "update"], stdout=subprocess.DEVNULL)


if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("usage: bootstrap_helm_repos.py <library-chart-dir>", file=sys.stderr)
        sys.exit(2)
    main(sys.argv[1])
'''
    local('cat > ' + bootstrap_repos_script_path + " <<'__SUSE_RDA_PY_EOF__'\n" + bootstrap_repos_script_src + "\n__SUSE_RDA_PY_EOF__", echo_off=True, quiet=True)

    # Speed: skip helm dep update when the cache is fresh.
    #   - --skip-refresh: don't update the 15+ helm repos (metallb, harbor,
    #     longhorn, rancher, ...). Wasted work because our deps use oci://
    #     URLs that bypass helm's repo cache entirely.
    #   - "Chart.lock newer than Chart.yaml + charts/*.tgz exists" guard:
    #     skip the dep update + alignment loop entirely. Saves ~5-15s per
    #     Tiltfile reload — these reloads happen on every save in the chart
    #     tree, so the win compounds. helm dep build would be even faster
    #     but requires a lock; we keep `update --skip-refresh` for the
    #     first-run / after-upgrade case where the lock isn't present yet.
    helm_dep_script = (
        'set -e; ' +
        'if [ -d "' + chart_path + '/charts" ]; then ' +
        '  for sub in "' + chart_path + '"/charts/*/; do ' +
        '    [ -d "$sub" ] || continue; ' +
        '    [ -f "$sub/Chart.yaml" ] || continue; ' +
        '    grep -q "^dependencies:" "$sub/Chart.yaml" || continue; ' +
        # Filter the library's deps down to only what's enabled in the
        # project's values. Cuts AppCo OCI pulls from N (every catalog
        # chart) to k (only the ones services[] turned on) per scenario.
        # Reads the project's values.yaml + rda render's overlay so the
        # filter sees both static + DSL-derived enabled flags. Idempotent:
        # backs up to Chart.yaml.full on first run, re-derives every run
        # so disable→enable cycles work.
        # No `|| true` here: a missing PyYAML / parse error / write error
        # in the filter would leave Chart.yaml un-filtered and helm
        # would pull every catalog entry, including HTTP-source repos
        # the user hasn't registered. Better to fail loud with the
        # filter's own remediation message than to mask it as a
        # downstream `helm-manager-<sha>` cache miss two layers later.
        '    python3 "' + filter_script_path + '" "$sub" ' +
        '      "' + chart_path + '/values.yaml" ' +
        '      "' + chart_path + '/.rda/values.generated.yaml" || ' +
        '      { echo "[suse_rda] FATAL: filter_enabled_deps.py failed for $sub"; exit 1; }; ' +
        # Pre-flight: register any non-OCI helm repo referenced by the
        # library Chart.yaml.full, so the subsequent
        # `helm dep update --skip-refresh` can find their indexes.
        # Idempotent + cheap. PyYAML required (already enforced above).
        '    python3 "' + bootstrap_repos_script_path + '" "$sub" || ' +
        '      { echo "[suse_rda] FATAL: bootstrap_helm_repos.py failed for $sub"; exit 1; }; ' +
        # Fast-path: lock fresh AND charts/ populated -> skip update.
        '    if [ -f "$sub/Chart.lock" ] && [ "$sub/Chart.lock" -nt "$sub/Chart.yaml" ] && ' +
        '       [ -d "$sub/charts" ] && [ -n "$(ls -A "$sub/charts" 2>/dev/null)" ]; then ' +
        '      echo "[suse_rda] $sub deps up to date, skipping helm dep update"; ' +
        '      python3 "' + align_script_path + '" "$sub"; ' +
        '      continue; ' +
        '    fi; ' +
        '    echo "[suse_rda] helm dep update --skip-refresh $sub"; ' +
        '    helm dependency update --skip-refresh "$sub"; ' +
        # AppCo packaging quirk: their Helm charts publish OCI artifact
        # tags like "0.4.4-29.1" but Chart.yaml inside says version
        # "0.4.4". Helm matches deps against the INTERNAL version, so
        # when the library declares postgresql at "0.4.4-29.1" the alias
        # silently fails to resolve at template time and parent values
        # never reach the sub-chart (no app user, no auth db). Patch
        # each pulled sub-chart to align its internal version with what
        # the parent expects. Drop when AppCo aligns version<->tag.
        '    python3 "' + align_script_path + '" "$sub"; ' +
        '  done; ' +
        'fi'
    )
    local(helm_dep_script, echo_off=True, quiet=False)

    # Ignore helm-managed paths so Tilt doesn't reload-loop. helm dep update
    # writes .tgz files into charts/<sub>/charts/, plus tmpcharts-* dirs and
    # Chart.lock. Tilt watches the project tree by default; without these
    # ignores every helm dep update triggers a reload that re-runs helm dep
    # update -> infinite loop.
    # watch_settings(ignore=...) is GLOBAL — files matched are removed
    # from ALL watch trees including live_update sync. So we keep this
    # list narrow: only the helm-managed dynamic paths that would
    # otherwise cause infinite Tiltfile reload loops on helm dep update
    # output. We do NOT include src/ here even though src/ changes do
    # trigger a Tiltfile reload (because helm() watches chart_path
    # recursively) — ignoring src/ would also stop live_update from
    # syncing src/ into the running container.
    #
    # The Tiltfile reload cost on src/ saves is acceptable because:
    #   - the local() helm dep update / alignment cache via Helm's own
    #     state and complete in <1s when nothing changed
    #   - live_update's sync runs in parallel and the runtime watcher
    #     (nodemon -L for nodejs) still picks up the change
    # If users find the reload too noisy, the longer-term fix is to
    # split the chart into a sub-directory so helm() doesn't watch the
    # app source — out of scope for v0.7.
    watch_settings(ignore=[
        chart_path + '/charts/*/charts',
        chart_path + '/charts/*/tmpcharts-*',
        chart_path + '/charts/*/Chart.lock',
        chart_path + '/Chart.lock',
    ])

    # Default values file follows chart_path. Bundle v0.8+ ships values.yaml
    # under chart/, so when chart_path='chart' the defaults are 'chart/values.yaml'.
    # Users overriding chart_values_files pass paths relative to the Tiltfile.
    if chart_values_files == None:
        chart_values_files = [chart_path + '/values.yaml']

    # ─── Namespace resolution (NS Phase A + 0.1.47 single-source-of-truth) ──
    # Shell out to `rda namespace expand` which reads `.rda/project.yaml`
    # under namespace.local, substitutes {{.project}} / {{.user}}, and
    # prints the resolved namespace on stdout. Single source of truth from
    # rda-cli 0.1.47+: the previous Starlark expansion that lived inline
    # here is gone, replaced by this one shell-out. Drift between the
    # CLI's expander and ours is no longer possible because there's only
    # one expander now.
    #
    # Fallback path: when `rda` isn't on PATH (older bundle / fresh
    # checkout before `go install`), or when the project predates
    # rda-cli's 0.1.47, we fall back to a tiny Starlark expander that
    # handles the common case ({{.project}} default, {{.user}} from
    # $USER). Same shape as before; just no longer the canonical one.
    rda_can_expand = str(local(
        'command -v rda > /dev/null 2>&1 && rda namespace --help > /dev/null 2>&1 && echo yes || echo no',
        quiet=True, echo_off=True)).strip()
    if rda_can_expand == 'yes':
        namespace = str(local('rda namespace expand', quiet=True, echo_off=True)).strip()
        if not namespace:
            fail('suse_app: `rda namespace expand` returned empty output. Check `.rda/project.yaml`.')
    else:
        # Legacy fallback: in-Tiltfile expander (kept simple — covers UC1
        # and UC2 patterns; for richer cases the user should upgrade to
        # rda-cli 0.1.47+ which owns the canonical logic).
        project_meta = read_yaml('.rda/project.yaml', default={})
        ns_template = ((project_meta.get('namespace', {}) or {}).get('local', '') or '{{.project}}')
        user_value = str(local('echo "${USER:-default}"', quiet=True, echo_off=True)).strip() or 'default'
        namespace = ns_template
        for token, value in [('{{.project}}', name), ('{{ .project }}', name),
                             ('{{.user}}', user_value), ('{{ .user }}', user_value)]:
            namespace = namespace.replace(token, value)
        if '{{' in namespace or '}}' in namespace:
            fail((
                'suse_app: namespace template %r contains an unrecognised token ' +
                'after expansion (got %r). Allowed tokens: {{.project}}, {{.user}}. ' +
                'Edit .rda/project.yaml namespace.local to fix, or install rda 0.1.47+ ' +
                'so this extension can shell out to `rda namespace expand` instead.'
            ) % (ns_template, namespace))

    # Pre-create the namespace idempotently. Tilt invokes `helm template`
    # (not `helm install --create-namespace`) so the namespace must exist
    # before k8s_yaml applies the rendered manifests. `kubectl create
    # --dry-run=client | kubectl apply` is idempotent — succeeds whether
    # the namespace is new or already there.
    local(
        'kubectl create namespace ' + namespace +
        ' --dry-run=client -o yaml | kubectl apply -f -',
        quiet=True, echo_off=True)

    # Mirror the application-collection imagePullSecret from `default` to
    # the deploy namespace if it's missing. Background:
    #   - The Application Collection Rancher Desktop extension installs
    #     the Secret in `default` only. With NS Phase A (rda 0.1.43+),
    #     every project deploys to its own namespace (`{{.project}}` or
    #     a multi-dev `{{.project}}-{{.user}}` template), so the Secret
    #     is never automatically present where it's needed.
    #   - The pod's spec carries `imagePullSecrets: [application-collection]`
    #     unconditionally. Without the Secret in NS, kubelet logs
    #     `Unable to retrieve some image pull secrets`. App image pulls
    #     from dp.apps.rancher.io (BCI base, AppCo subchart images) all
    #     fail with ImagePullBackOff — locally Tilt can mask this by
    #     building images itself, but any real subchart pull cracks open.
    #
    # Strategy:
    #   1. If the target NS already has the Secret → skip silently.
    #   2. Else if `default` has it → kubectl get -o yaml | sed | apply.
    #      Strips namespace + cluster-bound metadata so apply lands in
    #      the new ns. Idempotent (apply, not create).
    #   3. Else loud failure with the remediation hint pointing at
    #      `helm registry login` + the AppCo extension docs.
    #
    # Three escape hatches to coexist with operator-managed distribution
    # (kubernetes-reflector / External Secrets / GitOps / manual):
    #
    #   1. Env var SUSE_RDA_SKIP_PULLSECRET_MIRROR=1 (cluster-wide).
    #   2. Namespace label rda.suse.com/pullsecret-managed-by=operator
    #      — set this on a project NS to declare "an operator owns the
    #      pullsecret here, hands off". Per-NS, persistent in YAML.
    #   3. Source-side annotation: if Secret/application-collection in
    #      `default` carries `external-secrets.io/owned-by` or
    #      `reflector.v1.k8s.emberstack.com/reflection-allowed=true` we
    #      take that as proof an operator distributes it and we step
    #      back — letting the operator's controller reconcile in its
    #      own time on the project NS.
    #
    # Step 0 (target-NS already has it) is the universal safety net:
    # whatever distribution mechanism wrote it first, we don't touch.
    if os.getenv('SUSE_RDA_SKIP_PULLSECRET_MIRROR', '') != '1':
        local(
            "set -e; " +
            # Step 0: target NS already has the Secret — done.
            "if kubectl get secret -n " + namespace + " application-collection " +
            ">/dev/null 2>&1; then exit 0; fi; " +
            # Step 0b: target NS is operator-managed via label.
            "if [ \"$(kubectl get ns " + namespace + " -o " +
            "jsonpath='{.metadata.labels.rda\\.suse\\.com/pullsecret-managed-by}' " +
            "2>/dev/null)\" = 'operator' ]; then " +
            "echo '[suse_rda] skipping pullsecret mirror " +
            "(ns " + namespace + " labelled rda.suse.com/pullsecret-managed-by=operator)'; " +
            "exit 0; fi; " +
            # Step 0c: source Secret is operator-managed (ESO / reflector).
            # Don't fight the operator — step back and let its controller
            # propagate to the project NS on its own.
            "if [ -n \"$(kubectl get secret -n default application-collection -o " +
            "jsonpath='{.metadata.annotations.external-secrets\\.io/owned-by}' " +
            "2>/dev/null)\" ]; then " +
            "echo '[suse_rda] skipping pullsecret mirror " +
            "(default Secret has external-secrets.io annotation; ESO will distribute)'; " +
            "exit 0; fi; " +
            "if [ \"$(kubectl get secret -n default application-collection -o " +
            "jsonpath='{.metadata.annotations.reflector\\.v1\\.k8s\\.emberstack\\.com/reflection-allowed}' " +
            "2>/dev/null)\" = 'true' ]; then " +
            "echo '[suse_rda] skipping pullsecret mirror " +
            "(default Secret has reflector annotation; kubernetes-reflector will distribute)'; " +
            "exit 0; fi; " +
            # Step 1: source missing — loud fail.
            "if ! kubectl get secret -n default application-collection " +
            ">/dev/null 2>&1; then " +
            "echo '[suse_rda] FATAL: Secret/application-collection not found " +
            "in `default` (the AppCo Rancher Desktop extension would normally " +
            "install it there). Either install/launch the AppCo extension, " +
            "OR run `helm registry login dp.apps.rancher.io` then bootstrap " +
            "the Secret manually via kubectl create secret docker-registry; " +
            "OR set SUSE_RDA_SKIP_PULLSECRET_MIRROR=1 if your cluster uses " +
            "kubernetes-reflector / External Secrets to distribute it.' >&2; " +
            "exit 1; fi; " +
            # sed strips instance-bound metadata (namespace + uid +
            # resourceVersion + creationTimestamp) so the doc is
            # namespace-portable. kubectl apply -n <target> then anchors
            # it to the deploy NS. No jq dep — macOS doesn't ship one.
            "kubectl get secret -n default application-collection -o yaml | " +
            "sed -e '/^  namespace:/d' " +
            "-e '/^  uid:/d' " +
            "-e '/^  resourceVersion:/d' " +
            "-e '/^  creationTimestamp:/d' | " +
            "kubectl apply -n " + namespace + " -f - >/dev/null && " +
            "echo '[suse_rda] mirrored Secret/application-collection " +
            "default -> " + namespace + "'",
            quiet=False, echo_off=True)

    # ─── DSL projection (rda render) ────────────────────────────────────
    # Helm resolves sub-chart values BEFORE templates run, so the library
    # chart's _helpers.tpl can't inject services[].auth.user.name into
    # postgresql.auth.username at template time. The projection has to
    # happen out of band — `rda render` does it pre-helm. We call it here,
    # right before `helm(...)`, so chart/values.generated.yaml is fresh
    # for every tilt up. Spec: idefxH/rda-cli/rda.md BEHAVIOR: render.
    # Closes idefxH/rda-opinion-bundle-example#66.
    #
    # Wiring choices:
    #   - We call `rda render` (NOT --check) at every tilt up. Generating
    #     is fast (millisecond-class for typical projects); --check would
    #     just defer the same work to a second invocation if it found
    #     drift. CI is the right place for --check.
    #   - The generated overlay is APPENDED to chart_values_files so helm
    #     reads the user's values + the projection. Order matters: user
    #     values first (they're the truth), generated overlay second
    #     (Helm's value-merge convention is later-wins, which is what we
    #     want — the projected values_mapping output overrides any stale
    #     manual entries the user may have left from before they adopted
    #     `rda render`).
    #   - Missing rda binary: graceful warning, no fail. Inner-loop dev
    #     against an unreleased rda branch shouldn't be blocked. The
    #     downstream helm template will fail loud anyway via
    #     validateConsistency if the user hasn't manually maintained the
    #     equivalent values.
    rda_present = str(local(
        'command -v rda > /dev/null 2>&1 && echo present || echo missing',
        quiet=True, echo_off=True)).strip()
    if rda_present == 'present':
        # Run from chart_path's parent: `rda render` resolves the project
        # via cwd, and the project's chart_dir is computed relative to
        # the .rda/project.yaml location.
        local('rda render', quiet=True, echo_off=False)
        # Look for the overlay at the new path first (rda-cli v0.1.38+:
        # chart/.rda/values.generated.yaml), then fall back to the old
        # path (chart/values.generated.yaml) for projects that were
        # rendered with an older CLI. Both are valid; whichever exists
        # is what `helm` should consume. The fallback gets the dev a
        # working tilt up while they upgrade.
        new_overlay = chart_path + '/.rda/values.generated.yaml'
        old_overlay = chart_path + '/values.generated.yaml'
        if os.path.exists(new_overlay):
            generated_overlay = new_overlay
        elif os.path.exists(old_overlay):
            generated_overlay = old_overlay
            print('suse_rda: note — using legacy ' + old_overlay +
                  '. rda-cli v0.1.38+ writes to chart/.rda/values.generated.yaml; ' +
                  'next `rda render` will migrate. You can delete the legacy ' +
                  'file once chart/.rda/values.generated.yaml exists.')
        else:
            generated_overlay = ''
        # Only append when render actually produced the file (it does
        # unconditionally — see render.go's writeAtomic — but stay
        # defensive in case the user is on an older rda binary that
        # predates BEHAVIOR: render).
        if generated_overlay != '':
            # De-dup: if the user already passed the overlay in
            # chart_values_files, don't add it twice (Helm tolerates
            # dup files but the warning would confuse).
            if generated_overlay not in chart_values_files:
                chart_values_files = chart_values_files + [generated_overlay]
    else:
        print('suse_rda: warning — `rda` not on PATH; chart/.rda/values.generated.yaml ' +
              'will not be regenerated. Install rda CLI to keep services[] DSL ' +
              'in sync with sub-chart values. See idefxH/rda-cli.')

    k8s_yaml(helm(
        chart_path,
        name=name,
        namespace=namespace,
        values=chart_values_files,
    ))

    # Surface the application Service on the requested port. Convention:
    # local port == container port, so curl http://localhost:<port> works
    # the same as in production behind an Ingress.
    #
    # Auto-discover ingress hosts from the project's values.yaml so the
    # Tilt resource card shows clickable Ingress links alongside the
    # port-forward. Reads `suse-library.ingress` for the app, and each
    # sub-chart's own ingress block for the services (grafana follows
    # the standard `<chart>.ingress` shape; prometheus puts it under
    # `<chart>.server.ingress`). User-defined values files override
    # these via Tilt's standard --values stacking.
    parsed_values = []
    for vfile in chart_values_files:
        parsed_values.append(read_yaml(vfile, default={}))

    # Derive `port` from chart/values.yaml when the caller didn't pass one.
    # The library chart's deployment.yaml renders `containerPort: {{ .Values.port }}`
    # and the Service maps Service.targetPort to the same value, so
    # `suse-library.port` is the canonical container port. Reading it
    # here keeps the Tiltfile DRY: callers don't have to remember to set
    # the same number in two places. Closes the same drift class as
    # rda-cli#65 (single source of truth).
    #
    # Resolution order (last wins, matches Helm's --values stacking):
    #   1. library chart default (8080)
    #   2. user's chart/values.yaml suse-library.port
    #   3. user-overridden values files
    #   4. explicit port=NNN in suse_app(...) — fails fast on mismatch
    discovered_port = 8080
    for cfg in parsed_values:
        lib = (cfg.get('suse-library', {}) or {}) if cfg else {}
        if 'port' in lib:
            discovered_port = lib['port']
    if port == None:
        port = discovered_port
    elif port != discovered_port:
        fail((
            'suse_app: port=%d passed explicitly but chart/values.yaml has ' +
            'suse-library.port=%d. The two would drift on every edit. ' +
            'Drop the port argument from suse_app(...) — values.yaml is the ' +
            'source of truth (see rda-docs/concepts/dsl.md). If you really ' +
            'need to override, change values.yaml.'
        ) % (port, discovered_port))

    # Auto-discover services from `suse-library.services[]` (the unified
    # DSL in bundle v0.10+). Each entry has {binding, type, provisioning}
    # and maps to (binding -> type) for the port-forward registration
    # below.
    #
    # An explicit `services={...}` argument disables auto-discovery so a
    # caller can register services the chart doesn't deploy itself, or
    # narrow the surface to a subset.
    #
    # We dropped the pre-DSL legacy path (`suse-library.<chart>.enabled`
    # without `services[]`) when the bundle moved to DSL-only at v0.10.
    # If you're on a bundle <= v0.9, pin the extension to its 0.1.x line
    # or pass `services={...}` explicitly.
    if services == None:
        services = {}
        # Merged view across parsed_values:
        #   - services[] entries come from chart/values.yaml (the user's
        #     DSL) — overlay never has services[].
        #   - chart-level <chart>.enabled comes from the overlay (written
        #     by `rda render` for every enabled local service) OR from
        #     chart/values.yaml on pre-0.1.38 projects that wrote it
        #     manually. Either source counts.
        #
        # Earlier impl looped per-cfg and looked up <chart>.enabled in
        # the SAME cfg as the services[] entry. That broke for the
        # canonical post-0.1.38 split: services[] is in values.yaml,
        # <chart>.enabled is in the overlay, so the check failed for
        # every service and Tilt never registered the workloads. Result:
        # auto-Ingress link never showed up in the UI for grafana /
        # prometheus / etc. Discovered live Apr 30 (issue #14, kind of).
        #
        # The fix: collect services[] and chart-level enabled separately
        # across ALL cfgs, then intersect. Last-wins on binding-name
        # de-dup matches Helm's --values stacking semantics.
        all_lib_blocks = []
        all_services_by_binding = {}
        for cfg in parsed_values:
            lib = (cfg.get('suse-library', {}) or {}) if cfg else {}
            all_lib_blocks.append(lib)
            for entry in (lib.get('services') or []):
                if entry.get('binding'):
                    all_services_by_binding[entry['binding']] = entry

        def _chart_enabled(stype):
            for lib in all_lib_blocks:
                if (lib.get(stype, {}) or {}).get('enabled'):
                    return True
            return False

        for binding in all_services_by_binding:
            entry = all_services_by_binding[binding]
            stype = entry.get('type')
            provisioning = entry.get('provisioning', 'local')
            # Only `local` provisioning deploys an in-cluster workload —
            # `shared` and `external` produce only the binding secret.
            # Skip both so we don't register a phantom k8s_resource Tilt
            # can't resolve.
            if provisioning != 'local':
                continue
            # services[].enabled drives deployment (rda-cli v0.1.38+,
            # bundle v0.11.6+). Default true if absent (back-compat with
            # pre-0.1.38 scaffolds; fresh scaffolds opt-in explicitly).
            # When false, the entry is inert: no binding-secret rendered,
            # no chart-level enable flipped by rda render, no sub-chart
            # deployed.
            if entry.get('enabled', True) == False:
                continue
            # Belt-and-braces: at least one cfg must have <chart>.enabled
            # true, otherwise the sub-chart isn't deployed and we'd
            # register a phantom k8s_resource.
            if not _chart_enabled(stype):
                continue
            if stype:
                services[binding] = stype

    def _ingress_links(block):
        ing = block.get('ingress', {}) if block else {}
        if not ing.get('enabled'):
            return []
        scheme = 'https' if ing.get('tls') else 'http'
        # Two ingress.hosts shapes in the wild:
        #   - simple list of strings: ["app.localtest.me"]   (grafana,
        #     prometheus, the app-level ingress block)
        #   - rich list of objects:   [{host: "...", paths: [...]}]
        #     (dex chart 0.24+, others that need per-host path matching)
        # Same Tilt UI link comes out either way — we just have to peel
        # the host string out of the dict shape.
        out = []
        for h in ing.get('hosts', []):
            if type(h) == "string":
                host = h
            elif type(h) == "dict":
                host = h.get('host', '')
            else:
                continue
            if not host:
                continue
            out.append(link(scheme + '://' + host, host))
        return out

    def _suse_lib_block(values_dict, *path):
        block = values_dict.get('suse-library', {}) or {}
        for key in path:
            block = (block.get(key, {}) or {}) if hasattr(block, 'get') else {}
        return block

    app_links = []
    for cfg in parsed_values:
        app_links.extend(_ingress_links(cfg.get('suse-library', {}) or {}))

    k8s_resource(
        workload=name,
        port_forwards='%d:%d' % (port, port),
        labels=[labels.get(name, 'app')],
        links=app_links,
    )

    # Surface each declared service on its conventional port. The
    # workload name is NOT always <release>-<chart-name> — some AppCo
    # charts add a master/replica suffix (redis → <release>-redis-master,
    # prometheus → <release>-prometheus-server, mariadb-galera variants
    # → <release>-mariadb-primary, etc.). The authoritative source of the
    # actual K8s resource name is the `service.host` template in the
    # bundle's library-chart/dsl-mappings.yaml — the same template the
    # library helper uses to build the binding-secret's `host` key.
    # We read that file (vendored at chart_path/charts/suse-library/
    # dsl-mappings.yaml after `helm dep update`), pick the chart-type's
    # entry, render the host template by substituting .Release.Name.
    # Fallback when the file is absent (older bundle) or the type isn't
    # catalogued: the legacy <release>-<service_type> assumption.
    mappings_path = chart_path + '/charts/suse-library/dsl-mappings.yaml'
    mappings_doc = read_yaml(mappings_path, default={'charts': {}})
    catalogued_charts = mappings_doc.get('charts', {})

    def workload_name_for(release, service_type):
        """Compute the rendered K8s workload name for a service type.

        dsl-mappings.yaml service.host is the FQDN since NS Phase C
        (e.g. '<release>-postgresql.<ns>.svc.cluster.local') so that
        cross-namespace shared bindings can resolve. But Tilt's
        k8s_resource(workload=...) wants the SHORT NAME (the Service /
        Deployment name within the namespace, e.g. '<release>-postgresql').
        We render the template, then strip everything from the first '.'
        onwards.
        """
        chart_entry = catalogued_charts.get(service_type, {})
        versions = chart_entry.get('versions', [])
        if not versions:
            return release + '-' + service_type
        # versions[0] is fine for now — Phase 2 can match against the
        # actually-vendored chart version via semverCompare.
        host_tpl = versions[0].get('service', {}).get('host', '')
        if not host_tpl:
            return release + '-' + service_type
        # Render the (very limited) Go template subset used in
        # dsl-mappings.yaml: just substitute {{ .Release.Name }} (with or
        # without spaces). Anything richer would need a real Go template
        # engine, which Starlark doesn't have.
        rendered = host_tpl.replace('{{ .Release.Name }}', release).replace('{{.Release.Name}}', release)
        # Trim the FQDN suffix — Tilt workload names are short.
        if '.' in rendered:
            rendered = rendered.split('.', 1)[0]
        return rendered

    seen_workloads = {}
    for binding_name, service_type in services.items():
        workload = workload_name_for(name, service_type)
        # Two bindings of the same type collapse to one workload —
        # register it once.
        if workload in seen_workloads:
            continue
        seen_workloads[workload] = True

        # Sub-chart ingress lookup. Grafana uses <chart>.ingress (flat).
        # Prometheus is special: the upstream chart puts the server
        # ingress under <chart>.server.ingress. Add more service types
        # here as the bundle grows.
        svc_links = []
        for cfg in parsed_values:
            svc_links.extend(_ingress_links(_suse_lib_block(cfg, service_type)))
            if service_type == 'prometheus':
                svc_links.extend(_ingress_links(_suse_lib_block(cfg, service_type, 'server')))

        if service_type in SERVICE_PORTS:
            svc_port = SERVICE_PORTS[service_type]
            k8s_resource(
                workload=workload,
                port_forwards='%d:%d' % (svc_port, svc_port),
                labels=[labels.get(workload, 'services')],
                links=svc_links,
            )
        else:
            # Unknown type: register the workload but skip port-forward.
            # The user can add their own k8s_resource call after suse_app()
            # if they need a non-standard port.
            k8s_resource(
                workload=workload,
                labels=[labels.get(workload, 'services')],
                links=svc_links,
            )
